[
  {
    "id": "m11-ch5-quiz",
    "type": "quiz",
    "title": "The Interactive Debate",
    "description": "Choose the best expression for each debate situation.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "You want to express a strong opinion: \"___ homework should be abolished.\"",
          "options": [
            "I strongly believe",
            "Maybe",
            "I'm not sure if",
            "Perhaps"
          ],
          "correct": 0,
          "explanation": "\"I strongly believe\" = strong opinion expression."
        },
        {
          "id": "q2",
          "type": "multiple-choice",
          "question": "Someone said something you disagree with. The most polite response is:",
          "options": [
            "You're wrong!",
            "I'm afraid I disagree.",
            "That's stupid.",
            "No way!"
          ],
          "correct": 1,
          "explanation": "\"I'm afraid I disagree\" = polite disagreement."
        },
        {
          "id": "q3",
          "type": "fill-blank",
          "question": "\"_____, technology has many benefits. _____, it also has drawbacks.\" (contrast)",
          "correct": "On one hand However",
          "explanation": "\"On one hand... However...\" sets up a balanced contrast."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "Which phrase adds a supporting argument?",
          "options": [
            "However",
            "On the other hand",
            "Furthermore",
            "But"
          ],
          "correct": 2,
          "explanation": "\"Furthermore\" adds a supporting argument to your point."
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "You agree enthusiastically with a classmate. You say:",
          "options": [
            "I couldn't agree more!",
            "I somewhat agree.",
            "I see your point, but...",
            "I'm not sure."
          ],
          "correct": 0,
          "explanation": "\"I couldn't agree more!\" = strongest agreement."
        },
        {
          "id": "q6",
          "type": "fill-blank",
          "question": "\"___ ___ ___, I think social media does more harm than good.\" (polite opinion)",
          "correct": "In my opinion",
          "explanation": "\"In my opinion\" is a clear, polite way to state your view."
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "In the OREO structure, what comes after \"Opinion\"?",
          "options": [
            "Example",
            "Restatement",
            "Reason",
            "Conclusion"
          ],
          "correct": 2,
          "explanation": "OREO: Opinion → Reason → Example → Opinion restated."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "Which is the best way to acknowledge the other side before disagreeing?",
          "options": [
            "I see your point, but...",
            "You don't understand.",
            "I don't care what you think.",
            "That's wrong."
          ],
          "correct": 0,
          "explanation": "\"I see your point, but...\" acknowledges + politely disagrees."
        },
        {
          "id": "q9",
          "type": "multiple-choice",
          "question": "\"___ , wearing school uniforms saves families money.\" Which connector concludes an argument?",
          "options": [
            "Furthermore",
            "However",
            "In conclusion",
            "Although"
          ],
          "correct": 2,
          "explanation": "\"In conclusion\" signals you're wrapping up your argument."
        },
        {
          "id": "q10",
          "type": "fill-blank",
          "question": "\"That's a very ___ ___. I hadn't thought of it that way.\" (acknowledging a good argument)",
          "correct": "good point",
          "explanation": "\"That's a good point\" acknowledges someone's argument respectfully."
        },
        {
          "id": "q11",
          "type": "multiple-choice",
          "question": "Which connector introduces a reason?",
          "options": [
            "Nevertheless",
            "Moreover",
            "Due to",
            "In contrast"
          ],
          "correct": 2,
          "explanation": "\"Due to\" introduces a cause/reason for something."
        },
        {
          "id": "q12",
          "type": "multiple-choice",
          "question": "\"_____ I respect your opinion, I have a different view.\" Which word fits?",
          "options": [
            "Because",
            "Although",
            "Furthermore",
            "Therefore"
          ],
          "correct": 1,
          "explanation": "\"Although I respect your opinion\" = polite concession before disagreeing."
        }
      ]
    }
  },
