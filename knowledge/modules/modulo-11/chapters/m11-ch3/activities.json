  {
    "id": "m11-ch3-flash",
    "type": "flashcard",
    "title": "Diferencias Sutiles",
    "description": "Domina los contrastes entre modales que parecen similares.",
    "props": {
      "cards": [
        {
          "id": "m1",
          "front": "MUST vs HAVE TO",
          "back": "MUST = personal/internal obligation\nHAVE TO = external obligation",
          "example": "I must study harder (my decision). I have to wear a uniform (company rule)."
        },
        {
          "id": "m2",
          "front": "MUSTN'T vs DON'T HAVE TO",
          "back": "MUSTN'T = prohibited, forbidden\nDON'T HAVE TO = not necessary, optional",
          "example": "You mustn't cheat (prohibited). You don't have to come (it's optional)."
        },
        {
          "id": "m3",
          "front": "CAN vs MAY (permission)",
          "back": "CAN = informal permission\nMAY = formal/polite permission",
          "example": "Can I sit here? (casual) May I come in? (formal)"
        },
        {
          "id": "m4",
          "front": "SHOULD vs MUST",
          "back": "SHOULD = advice, recommendation\nMUST = strong obligation",
          "example": "You should exercise more (advice). You must stop at a red light (obligation)."
        },
        {
          "id": "m5",
          "front": "MIGHT vs MAY (possibility)",
          "back": "MIGHT = less likely possibility\nMAY = more likely possibility",
          "example": "It might snow (unlikely). It may rain (more likely)."
        },
        {
          "id": "m6",
          "front": "CAN vs COULD (ability)",
          "back": "CAN = present ability\nCOULD = past ability or polite request",
          "example": "I can swim (now). I could swim when I was 5 (past). Could you help me? (polite)"
        },
        {
          "id": "m7",
          "front": "HAVE TO vs NEED TO",
          "back": "Both express necessity.\nHAVE TO = stronger, more common\nNEED TO = slightly softer",
          "example": "I have to finish this by Monday. I need to call my mom."
        },
        {
          "id": "m8",
          "front": "SHOULD vs OUGHT TO",
          "back": "Both give advice. Same meaning.\nSHOULD = more common in speech\nOUGHT TO = slightly more formal",
          "example": "You should/ought to apologize."
        },
        {
          "id": "m9",
          "front": "CAN'T vs MUSTN'T",
          "back": "CAN'T = not allowed / impossible\nMUSTN'T = prohibited (stronger)",
          "example": "You can't park here (not allowed). You mustn't touch that wire (dangerous!)."
        },
        {
          "id": "m10",
          "front": "MAY vs CAN (formal vs informal)",
          "back": "MAY = formal contexts, writing\nCAN = everyday speech",
          "example": "May I be excused? (formal) Can I go now? (informal)"
        }
      ]
    }
  },
