  {
    "id": "m11-ch1-flash",
    "type": "flashcard",
    "title": "Participios Irregulares",
    "description": "Master the three most important irregular verb forms.",
    "props": {
      "cards": [
        {
          "id": "pp1",
          "front": "GO 🚶",
          "back": "go → went → gone",
          "example": "I have gone to that restaurant many times."
        },
        {
          "id": "pp2",
          "front": "SEE 👀",
          "back": "see → saw → seen",
          "example": "She has seen that movie before."
        },
        {
          "id": "pp3",
          "front": "EAT 🍽️",
          "back": "eat → ate → eaten",
          "example": "Have you ever eaten Thai food?"
        },
        {
          "id": "pp4",
          "front": "WRITE ✍️",
          "back": "write → wrote → written",
          "example": "He has written three novels."
        },
        {
          "id": "pp5",
          "front": "TAKE 🤲",
          "back": "take → took → taken",
          "example": "I have taken this class before."
        },
        {
          "id": "pp6",
          "front": "GIVE 🎁",
          "back": "give → gave → given",
          "example": "She has given a speech at the conference."
        },
        {
          "id": "pp7",
          "front": "SPEAK 🗣️",
          "back": "speak → spoke → spoken",
          "example": "Have you ever spoken in public?"
        },
        {
          "id": "pp8",
          "front": "BREAK 💔",
          "back": "break → broke → broken",
          "example": "He has broken his arm twice."
        },
        {
          "id": "pp9",
          "front": "DRIVE 🚗",
          "back": "drive → drove → driven",
          "example": "She has driven across the country."
        },
        {
          "id": "pp10",
          "front": "SWIM 🏊",
          "back": "swim → swam → swum",
          "example": "I have swum in the ocean many times."
        },
        {
          "id": "pp11",
          "front": "RIDE 🐴",
          "back": "ride → rode → ridden",
          "example": "Have you ever ridden a horse?"
        },
        {
          "id": "pp12",
          "front": "CHOOSE 🤔",
          "back": "choose → chose → chosen",
          "example": "They have chosen a new leader."
        },
        {
          "id": "pp13",
          "front": "FORGET 🤦",
          "back": "forget → forgot → forgotten",
          "example": "I have forgotten her name."
        },
        {
          "id": "pp14",
          "front": "FLY ✈️",
          "back": "fly → flew → flown",
          "example": "She has flown to Europe several times."
        },
        {
          "id": "pp15",
          "front": "GROW 🌱",
          "back": "grow → grew → grown",
          "example": "The city has grown a lot recently."
        },
        {
          "id": "pp16",
          "front": "KNOW 🧠",
          "back": "know → knew → known",
          "example": "I have known him since childhood."
        },
        {
          "id": "pp17",
          "front": "SING 🎤",
          "back": "sing → sang → sung",
          "example": "She has sung at many concerts."
        },
        {
          "id": "pp18",
          "front": "DRINK 🥤",
          "back": "drink → drank → drunk",
          "example": "Have you ever drunk green tea?"
        },
        {
          "id": "pp19",
          "front": "BEGIN 🏁",
          "back": "begin → began → begun",
          "example": "The meeting has already begun."
        },
        {
          "id": "pp20",
          "front": "WEAR 👗",
          "back": "wear → wore → worn",
          "example": "She has worn that dress three times."
        }
      ]
    }
