  {
    "id": "m11-ch1-quiz",
    "type": "quiz",
    "title": "Past Simple or Present Perfect?",
    "description": "Choose the correct verb tense according to the context. Be careful with temporary markers!",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "I ___ (live) in this city for 10 years.",
          "options": [
            "lived",
            "have lived",
            "am living",
            "was living"
          ],
          "correct": 1,
          "explanation": "\"For 10 years\" → present perfect: \"I have lived here for 10 years.\""
        },
        {
          "id": "q2",
          "type": "multiple-choice",
          "question": "She ___ (visit) Rome last summer.",
          "options": [
            "has visited",
            "visited",
            "have visited",
            "visits"
          ],
          "correct": 1,
          "explanation": "\"Last summer\" = specific time → past simple: \"She visited Rome last summer.\""
        },
        {
          "id": "q3",
          "type": "fill-blank",
          "question": "They have ___ (eat) at that restaurant many times.",
          "correct": "eaten",
          "explanation": "Eat → ate → eaten. Present perfect: \"They have eaten there many times.\""
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "Have you ever ___ to Japan?",
          "options": [
            "went",
            "go",
            "been",
            "going"
          ],
          "correct": 2,
          "explanation": "\"Have you ever been to...?\" is the correct form for asking about travel experiences."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "She has ___ (write) three books so far.",
          "correct": "written",
          "explanation": "Write → wrote → written. \"She has written three books so far.\""
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "I ___ that movie yesterday.",
          "options": [
            "have seen",
            "saw",
            "have saw",
            "seeing"
          ],
          "correct": 1,
          "explanation": "\"Yesterday\" = specific time → past simple: \"I saw that movie yesterday.\""
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "He has ___ finished his homework.",
          "options": [
            "yet",
            "already",
            "ever",
            "ago"
          ],
          "correct": 1,
          "explanation": "\"Already\" goes with present perfect for completed actions: \"He has already finished.\""
        },
        {
          "id": "q8",
          "type": "fill-blank",
          "question": "We have known each other ___ 2015.",
          "correct": "since",
          "explanation": "\"Since\" + specific point in time: \"We have known each other since 2015.\""
        },
        {
          "id": "q9",
          "type": "multiple-choice",
          "question": "I have ___ been to Africa. I want to go someday.",
          "options": [
            "ever",
            "never",
            "already",
            "just"
          ],
          "correct": 1,
          "explanation": "\"Never\" = not at any time: \"I have never been to Africa.\""
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "___ you finished the report yet?",
          "options": [
            "Did",
            "Have",
            "Do",
            "Are"
          ],
          "correct": 1,
          "explanation": "\"Yet\" → present perfect question: \"Have you finished the report yet?\""
        },
        {
          "id": "q11",
          "type": "fill-blank",
          "question": "She has ___ (see) that movie three times.",
          "correct": "seen",
          "explanation": "See → saw → seen. \"She has seen that movie three times.\""
        },
        {
          "id": "q12",
          "type": "multiple-choice",
          "question": "They ___ to London in 2019.",
          "options": [
            "have gone",
            "went",
            "have went",
            "go"
          ],
          "correct": 1,
          "explanation": "\"In 2019\" = specific time → past simple: \"They went to London in 2019.\""
        }
      ]
    }
  },
