  {
    "id": "m9-ch2-quiz",
    "type": "quiz",
    "title": "Presente Simple vs. Continuo",
    "description": "Habit or action in progress? Choose the correct form of the verb.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "She ___ a book every evening. (routine)",
          "options": [
            "is reading",
            "reads",
            "reading",
            "read"
          ],
          "correct": 1,
          "explanation": "Routine → presente simple: \"She reads a book every evening.\""
        },
        {
          "id": "q2",
          "type": "multiple-choice",
          "question": "Look! She ___ a very interesting book. (now)",
          "options": [
            "reads",
            "is reading",
            "read",
            "reading"
          ],
          "correct": 1,
          "explanation": "Right now → presente continuo: \"She is reading a very interesting book.\""
        },
        {
          "id": "q3",
          "type": "fill-blank",
          "question": "They ___ (play) soccer in the park right now.",
          "correct": "are playing",
          "explanation": "\"Right now\" → presente continuo: \"They are playing soccer.\""
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "He ___ to work every day. (habit)",
          "options": [
            "is going",
            "goes",
            "going",
            "go"
          ],
          "correct": 1,
          "explanation": "Every day → presente simple: \"He goes to work every day.\""
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "Listen! The birds ___. (at this moment)",
          "options": [
            "sing",
            "are singing",
            "sings",
            "singing"
          ],
          "correct": 1,
          "explanation": "\"Listen!\" → presente continuo: \"The birds are singing.\""
        },
        {
          "id": "q6",
          "type": "fill-blank",
          "question": "I ___ (not / watch) TV right now. I am studying.",
          "correct": "am not watching",
          "explanation": "Continuous negative: \"I am not watching TV.\""
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "We usually ___ dinner at 7 PM.",
          "options": [
            "are eating",
            "eat",
            "eating",
            "eats"
          ],
          "correct": 1,
          "explanation": "\"Usually\" → presente simple: \"We usually eat dinner at 7 PM.\""
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "___ she working today?",
          "options": [
            "Does",
            "Is",
            "Do",
            "Are"
          ],
          "correct": 1,
          "explanation": "Continuo interrogativo: \"Is she working today?\""
        },
        {
          "id": "q9",
          "type": "fill-blank",
          "question": "The children ___ (run) in the garden at the moment.",
          "correct": "are running",
          "explanation": "\"At the moment\" → continuo: \"The children are running.\" (double n)"
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "He ___ (make) a cake. Look at the kitchen!",
          "options": [
            "makes",
            "is making",
            "making",
            "make"
          ],
          "correct": 1,
          "explanation": "\"Look!\" → continuo. Make → making (drop -e): \"He is making a cake.\""
        }
      ]
    }
  },
