  {
    "id": "m9-ch3-flash",
    "type": "flashcard",
    "title": "Patrones de Preguntas",
    "description": "Aprende los patrones de cada tipo de pregunta con ejemplos completos.",
    "props": {
      "cards": [
        {
          "id": "p1",
          "front": "WHAT + do/does + subject + verb?",
          "back": "What do you do? → I am a teacher.\nWhat does she eat? → She eats salad.",
          "example": "What do you usually eat for breakfast?"
        },
        {
          "id": "p2",
          "front": "WHERE + do/does + subject + verb?",
          "back": "Where do you live? → I live in Tokyo.\nWhere does he work? → He works at a hospital.",
          "example": "Where do you usually study?"
        },
        {
          "id": "p3",
          "front": "WHEN + do/does + subject + verb?",
          "back": "When do you wake up? → I wake up at 7.\nWhen does the class start? → It starts at 9.",
          "example": "When does the movie start?"
        },
        {
          "id": "p4",
          "front": "WHO + is/are + complement?",
          "back": "Who is your best friend? → Maria is.\nWho are those people? → They are my neighbors.",
          "example": "Who is the new student?"
        },
        {
          "id": "p5",
          "front": "WHY + do/does + subject + verb?",
          "back": "Why do you study English? → Because I need it for work.\nWhy does she cry? → Because she is sad.",
          "example": "Why do you like this city?"
        },
        {
          "id": "p6",
          "front": "HOW + do/does + subject + verb?",
          "back": "How do you get to school? → I take the bus.\nHow does she cook? → She cooks very well.",
          "example": "How do you spell your name?"
        },
        {
          "id": "p7",
          "front": "DO/DOES + subject + verb? (Yes/No)",
          "back": "Do you speak English? → Yes, I do.\nDoes she like coffee? → No, she doesn't.",
          "example": "Do you have any brothers or sisters?"
        },
        {
          "id": "p8",
          "front": "IS/ARE + subject + complement? (Yes/No)",
          "back": "Is he a doctor? → Yes, he is.\nAre they at home? → No, they aren't.",
          "example": "Are you ready for the test?"
        },
        {
          "id": "p9",
          "front": "HOW MANY + plural noun + do/does...?",
          "back": "How many books do you have? → I have ten books.\nHow many students are there? → There are 30.",
          "example": "How many languages do you speak?"
        },
        {
          "id": "p10",
          "front": "HOW MUCH + uncountable noun...?",
          "back": "How much water do you drink? → Two liters.\nHow much is this? → It's $10.",
          "example": "How much time do we have?"
        },
        {
          "id": "p11",
          "front": "HOW OFTEN + do/does + subject + verb?",
          "back": "How often do you exercise? → Three times a week.\nHow often does it rain? → Often.",
          "example": "How often do you go to the movies?"
        },
        {
          "id": "p12",
          "front": "HOW OLD + is/are + subject?",
          "back": "How old are you? → I'm 25 years old.\nHow old is your brother? → He's 30.",
          "example": "How old is this building?"
        }
      ]
    }
  },
