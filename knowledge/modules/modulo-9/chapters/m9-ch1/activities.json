          ],
          "correct": 1,
          "explanation": "Boarding gate = Gate (at the airport)."
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "You want to buy a train ticket. You say:",
          "options": [
            "How much is a ticket to London?",
            "Give me ticket London",
            "I need go London",
            "Ticket London how much?"
