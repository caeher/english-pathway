    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "You arrive at the hotel front desk. What do you say?",
          "options": [
            "I'd like to check in, please",
            "Give me room",
            "I want sleep here",
            "Room now please"
          ],
          "correct": 0,
          "explanation": "The polite phrase is: \"I'd like to check in, please.\""
        },
        {
          "id": "q2",
          "type": "multiple-choice",
          "question": "You need to find the subway. What do you ask?",
          "options": [
            "Where subway?",
            "Subway is where?",
            "Where is the nearest subway station?",
            "I need subway"
          ],
          "correct": 2,
          "explanation": "Proper question form: \"Where is the nearest subway station?\""
        },
        {
          "id": "q3",
          "type": "fill-blank",
          "question": "I have a ____ for two nights at this hotel.",
          "correct": "reservation",
          "explanation": "Reservation = reservation. \"I have a reservation for two nights.\""
        },
        {
          "id": "q4",
          "type": "multiple-choice",
