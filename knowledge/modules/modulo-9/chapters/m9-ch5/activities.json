          "question": "\"She is a ___, ___ woman.\" (amable, joven)",
          "options": [
            "kind, young",
            "young, kind",
            "big, old",
            "small, new"
          ],
          "correct": 0,
          "explanation": "Opinion (kind) before age (young): \"She is a kind, young woman.\""
        },
        {
          "id": "q3",
          "type": "fill-blank",
          "question": "The opposite of \"tall\" is ___.",
          "correct": "short",
          "explanation": "Tall ↔ short. \"He is short.\""
