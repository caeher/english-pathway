  {
    "id": "m1-ch6-flash",
    "type": "flashcard",
    "title": "Essential Questions",
    "description": "Master the most important questions in basic English.",
    "props": {
      "cards": [
        {
          "id": "w1",
          "front": "WHAT",
          "back": "That? / Which? — Ask for things/information",
          "example": "What is your name? What time is it?"
        },
        {
          "id": "w2",
          "front": "WHERE",
          "back": "Where? — Ask about places",
          "example": "Where are you from? Where is the school?"
        },
        {
          "id": "w3",
          "front": "WHEN",
          "back": "When? — Ask for time",
          "example": "When is your birthday? When is the class?"
        },
        {
          "id": "w4",
          "front": "WHO",
          "back": "Who? — Ask for people",
          "example": "Who is your best friend? Who are they?"
        },
        {
          "id": "w5",
          "front": "WHY",
          "back": "Because? — Ask for reasons",
          "example": "Why are you late? —Because I missed the bus."
        },
        {
          "id": "w6",
          "front": "HOW",
          "back": "As? — Ask by way/state",
          "example": "How are you? How do you spell your name?"
        },
        {
          "id": "w7",
          "front": "HOW OLD",
          "back": "How many years?",
          "example": "How old are you? —I am 25 years old."
        },
        {
          "id": "w8",
          "front": "HOW MUCH",
          "back": "How much? (uncountable/price)",
          "example": "How much is this? How much water do you want?"
        },
        {
          "id": "w9",
          "front": "HOW MANY",
          "back": "How many? (accountant)",
          "example": "How many brothers do you have? How many students are there?"
        },
        {
          "id": "w10",
          "front": "HOW OFTEN",
          "back": "How often?",
          "example": "How often do you exercise? — Twice a week."
        },
        {
          "id": "w11",
          "front": "HOW FAR",
          "back": "How far? (distance)",
          "example": "How far is the airport? —It is 10 kilometers."
        },
        {
          "id": "w12",
          "front": "HOW LONG",
          "back": "How long? (duration)",
          "example": "How long is the movie? —Two hours."
        },
        {
          "id": "w13",
          "front": "HOW TALL",
          "back": "How high? (height)",
          "example": "How tall are you? — I am 1.75 meters."
        }
      ]
    }
