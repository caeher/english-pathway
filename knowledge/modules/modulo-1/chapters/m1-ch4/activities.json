[
  {
    "id": "m1-ch4-flash",
    "type": "flashcard",
    "title": "A, An, The + Plurals",
    "description": "Cards to master articles and plurals.",
    "props": {
      "cards": [
        {
          "id": "a1",
          "front": "TO",
          "back": "Indefinite article: before CONSONANT",
          "example": "a book, a car, a dog, a house, a pen"
        },
        {
          "id": "a2",
          "front": "A.N.",
          "back": "Indefinite article: before VOCAL (sound)",
          "example": "an apple, an egg, an umbrella, an orange"
        },
        {
          "id": "a3",
          "front": "THE",
          "back": "Definite article: something specific or unique",
          "example": "the sun, the moon, the book on the table"
        },
        {
          "id": "a4",
          "front": "A or AN? ___ hour",
          "back": "AN hour (H is silent)",
          "example": "I waited for an hour."
        },
        {
          "id": "a5",
          "front": "A or AN? ___university",
          "back": "A university (sounds /juː/)",
          "example": "She goes to a university in London."
        },
        {
          "id": "p1",
          "front": "book → ?",
          "back": "books (rule: +s)",
          "example": "I have three books."
        },
        {
          "id": "p2",
          "front": "bus → ?",
          "back": "buses (rule: +es)",
          "example": "There are two buses."
        },
        {
          "id": "p3",
          "front": "baby → ?",
          "back": "babies (rule: -y → -ies)",
          "example": "The babies are sleeping."
        },
        {
          "id": "p4",
          "front": "man → ?",
          "back": "menu (irregular)",
          "example": "The men are working."
        },
        {
          "id": "p5",
          "front": "woman → ?",
          "back": "women (irregular)",
          "example": "Three women are talking."
        },
        {
          "id": "p6",
          "front": "child → ?",
          "back": "children (irregular)",
          "example": "The children are playing."
        },
        {
          "id": "p7",
          "front": "tooth → ?",
          "back": "teeth (irregular)",
          "example": "Brush your teeth!"
        },
        {
          "id": "p8",
          "front": "foot → ?",
          "back": "feet (irregular)",
          "example": "My feet hurt."
        },
        {
          "id": "p9",
          "front": "mouse → ?",
          "back": "mice (irregular)",
          "example": "There are mice in the house!"
        },
        {
          "id": "p10",
          "front": "person → ?",
          "back": "people (irregular)",
          "example": "Many people are here."
        },
        {
          "id": "ap1",
          "front": "Appositive",
          "back": "Noun that modifies or complements another noun",
          "example": "Maria, my best friend, is coming. (my best friend = appositive)"
        },
        {
          "id": "ap2",
          "front": "Appositive with commas",
          "back": "When you give extra (non-essential) information",
          "example": "Paris, the capital of France, is beautiful."
        },
        {
          "id": "ap3",
          "front": "Appositive without commas",
          "back": "When it is essential to identify",
          "example": "My brother Carlos lives in Madrid."
        },
        {
          "id": "uc1",
          "front": "Uncountable: information",
          "back": "Not plural. I need some information. (NOT: an information)",
          "example": "This is useful information."
        },
        {
          "id": "uc2",
          "front": "Uncountable: advice",
          "back": "Not plural. Can you give me some advice?",
          "example": "I need advice about my job."
        },
        {
          "id": "uc3",
          "front": "Much vs Many",
          "back": "Much + uncountable. Many + accountant",
          "example": "How much water? How many books?"
        }
      ]
    }
  },
