  {
    "id": "m1-ch4-quiz",
    "type": "quiz",
    "title": "Articles and Plurals Quiz",
    "description": "Test your knowledge of a/an/the and plurals.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "Choose: \"___ apple a day keeps the doctor away.\"",
          "options": [
            "TO",
            "An",
            "The",
            "No article"
          ],
          "correct": 1,
          "explanation": "AN apple — \"apple\" starts with a vowel sound."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "I need ___ book from the library. (specific book)",
          "correct": "the",
          "explanation": "\"The\" because it's a specific book."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "What is the plural of \"child\"?",
          "options": [
            "children",
            "childes",
            "children",
            "childrens"
          ],
          "correct": 2,
          "explanation": "Child → children (irregular plural)."
        },
        {
          "id": "q4",
          "type": "fill-blank",
          "question": "She is ___ honest person. (a/an)",
          "correct": "an",
          "explanation": "\"An\" because \"honest\" has a silent H."
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "What is the plural of \"bus\"?",
          "options": [
            "bus",
            "buses",
            "busies",
            "bus"
          ],
          "correct": 1,
          "explanation": "Bus → buses (add -es after s)."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "\"___ university\" — A or AN?",
          "options": [
            "TO",
            "An"
          ],
          "correct": 0,
          "explanation": "\"A university\" — sounds like /juː/, a consonant sound."
        },
        {
          "id": "q7",
          "type": "fill-blank",
          "question": "The plural of \"tooth\" is ___",
          "correct": "teeth",
          "explanation": "Tooth → teeth (irregular plural)."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "Which sentence is correct?",
          "options": [
            "I see an elephant",
            "I see an elephant",
            "I see the elephant an",
            "I see elephant"
          ],
          "correct": 1,
          "explanation": "\"An elephant\" — \"elephant\" starts with a vowel sound."
        },
        {
          "id": "q9",
          "type": "multiple-choice",
          "question": "What is the plural of \"baby\"?",
          "options": [
            "babys",
            "babies",
            "babys",
            "babyies"
          ],
          "correct": 1,
          "explanation": "Baby → babies (consonant + y → ies)."
        },
        {
          "id": "q10",
          "type": "fill-blank",
          "question": "The plural of \"man\" is ___",
          "correct": "menu",
          "explanation": "Man → men (irregular plural)."
        },
        {
          "id": "q11",
          "type": "multiple-choice",
          "question": "In \"The dog barks\", what is the function of \"The dog\"?",
          "options": [
            "object",
            "Subject",
            "Object of preposition",
            "Predicate nominative"
          ],
          "correct": 1,
          "explanation": "\"The dog\" is the subject — it performs the action."
        },
        {
          "id": "q12",
          "type": "multiple-choice",
          "question": "In \"She is a teacher\", what is the function of \"a teacher\"?",
          "options": [
            "Subject",
            "object",
            "Object of preposition",
            "Predicate nominative"
          ],
          "correct": 3,
          "explanation": "\"A teacher\" is predicate nominative — it renames the subject after \"be\"."
        },
        {
          "id": "q13",
          "type": "multiple-choice",
          "question": "In \"Maria, my best friend, is coming\", what is \"my best friend\"?",
          "options": [
            "Subject",
            "object",
            "Appositive",
            "Predicate nominative"
          ],
          "correct": 2,
          "explanation": "\"My best friend\" is an appositive — it modifies/explains Maria."
        },
        {
          "id": "q14",
          "type": "multiple-choice",
          "question": "\"I need some ___.\" Which is correct?",
          "options": [
            "information",
            "information",
            "an information",
            "information"
          ],
          "correct": 0,
          "explanation": "\"Information\" is uncountable — not plural, not \"an\"."
        },
        {
          "id": "q15",
          "type": "multiple-choice",
          "question": "\"How ___ water do you need?\" (uncountable)",
          "options": [
            "many",
            "much",
            "some",
            "any"
          ],
          "correct": 1,
          "explanation": "Use \"much\" with uncountable nouns like water."
        }
      ]
    }
