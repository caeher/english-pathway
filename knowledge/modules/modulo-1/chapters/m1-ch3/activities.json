        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "\"We ___ friends.\" —Fill the blank.",
          "options": [
            "A.M",
            "is",
            "are",
            "be"
          ],
          "correct": 2,
          "explanation": "We ARE friends."
        },
        {
          "id": "q9",
          "type": "fill-blank",
          "question": "It ___ cold today. (to be)",
          "correct": "is",
          "explanation": "It IS cold today."
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "\"They ___ students.\" Choose the negative form.",
