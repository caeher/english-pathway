          "correct": 0,
          "explanation": "They AREN'T students (are not)."
        },
        {
          "id": "q11",
          "type": "multiple-choice",
          "question": "\"Is she a doctor?\" —Correct short answer:",
          "options": [
            "Yes, she's",
            "Yes, she is",
            "Yes, she",
            "Yes, it is she"
          ],
          "correct": 1,
          "explanation": "Short answer: Yes, she is. (We repeat the pronoun + be.)"
        },
        {
          "id": "q12",
          "type": "fill-blank",
          "question": "\"You're a student, ___ you?\" (tag question)",
          "correct": "aren't",
          "explanation": "With 'You're' (affirmative), the tag is 'aren't you?' (negative)."
        }
      ]
    }
