  {
    "id": "m1-ch3-flash",
    "type": "flashcard",
    "title": "Pronouns and \"To Be\"",
    "description": "Master each pronoun with its form of the verb \"to be.\"",
    "props": {
      "cards": [
        {
          "id": "p1",
          "front": "I + to be",
          "back": "I AM → I'm",
          "example": "I'm a student. I'm 20 years old. I'm happy."
        },
        {
          "id": "p2",
          "front": "YOU + to be",
          "back": "YOU ARE → You're",
          "example": "You're my best friend. You're very smart."
        },
        {
          "id": "p3",
          "front": "HE + to be",
          "back": "HE IS → He's",
          "example": "He's a doctor. He's tall. He's from Brazil."
        },
        {
          "id": "p4",
          "front": "SHE + to be",
          "back": "SHE IS → She's",
          "example": "She's a teacher. She's kind. She's 30 years old."
        },
        {
          "id": "p5",
          "front": "IT + to be",
          "back": "IT IS → It's",
          "example": "It's a dog. It's cold today. It's 3 o'clock."
        },
        {
          "id": "p6",
          "front": "WE + to be",
          "back": "WE ARE → We're",
          "example": "We're friends. We're from Mexico. We're ready."
        },
        {
          "id": "p7",
          "front": "THEY + to be",
          "back": "THEY ARE → They're",
          "example": "They're students. They're happy. They're here."
        },
        {
          "id": "p8",
          "front": "Negative: IS NOT",
          "back": "ISN'T (contraction)",
          "example": "He isn't here. She isn't sad. It isn't cold."
        },
        {
          "id": "p9",
          "front": "Negative: ARE NOT",
          "back": "AREN'T (contraction)",
          "example": "We aren't tired. They aren't from Spain. You aren't wrong."
        },
        {
          "id": "p10",
          "front": "Negative: AM NOT",
          "back": "I'M NOT (no contraction of amn't)",
          "example": "I'm not hungry. I'm not a doctor. I'm not late."
        },
        {
          "id": "p11",
          "front": "Short Answer: Are you...?",
          "back": "Yes, I am. / No, I'm not.",
          "example": "Are you tired? —Yes, I am."
        },
        {
          "id": "p12",
          "front": "Short Answer: Is she...?",
          "back": "Yes, she is. / No, she isn't.",
          "example": "Is she a doctor? —No, she isn't."
        },
        {
          "id": "p13",
          "front": "Tag: You're a student...",
          "back": "aren't you?",
          "example": "You're a student, aren't you? —Yes, I am."
        },
        {
          "id": "p14",
          "front": "Tag: She is from Spain...",
          "back": "isn't she?",
          "example": "She is from Spain, isn't she? —Yes, she is."
        }
      ]
    }
  },
