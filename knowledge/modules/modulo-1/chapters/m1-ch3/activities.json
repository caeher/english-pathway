        {
          "id": "q2",
          "type": "fill-blank",
          "question": "She ___ a doctor. (to be)",
          "correct": "is",
          "explanation": "She IS a doctor."
        },
        {
          "id": "q3",
          "type": "fill-blank",
          "question": "They ___ happy. (to be)",
          "correct": "are",
          "explanation": "They ARE happy."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "Which is the correct contraction of \"I am\"?",
          "options": [
            "I'm",
            "I'am",
            "Iam",
            "Im'"
          ],
          "correct": 0,
          "explanation": "I'm is the contraction of I am."
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "\"He ___ not here.\" —Fill the blank.",
          "options": [
            "A.M",
            "are",
            "is",
            "be"
          ],
          "correct": 2,
          "explanation": "He IS not here."
        },
        {
          "id": "q6",
          "type": "fill-blank",
          "question": "___ you a teacher? (question)",
          "correct": "Are",
          "explanation": "ARE you a teacher?"
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "Which pronoun do we use for a cat?",
          "options": [
            "I have",
            "She",
            "Item",
            "They"
          ],
          "correct": 2,
