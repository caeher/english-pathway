  {
    "id": "m10-ch2-flash",
    "type": "flashcard",
    "title": "Vocabulary in Context",
    "description": "Learn each word with its definition, placement and example of use.",
    "props": {
      "cards": [
        {
          "id": "f1",
          "front": "APPOINTMENT 📅",
          "back": "An appointment (medical, business). Collocations: make / schedule / cancel an appointment",
          "example": "I need to make an appointment with the dentist."
        },
        {
          "id": "f2",
          "front": "DEADLINE ⏰",
          "back": "Deadline to deliver something. Collocations: meet / miss the deadline",
          "example": "We need to meet the deadline by Friday."
        },
        {
          "id": "f3",
          "front": "RECEIPT 🧾",
          "back": "Receipt or proof of purchase. Collocations: keep / ask for the receipt",
          "example": "Always keep the receipt in case you need a refund."
        },
        {
          "id": "f4",
          "front": "COLLEAGUE 👥",
          "back": "Co-worker. Collocations: a close colleague, work with colleagues",
          "example": "My colleague helped me with the project."
        },
        {
          "id": "f5",
          "front": "SYMPTOM 🤒",
          "back": "Symptom of a disease. Collocations: show / have symptoms",
          "example": "What symptoms do you have?"
        },
        {
          "id": "f6",
          "front": "FURNITURE 🛋️",
          "back": "Muebles (sustantivo incontable). Collocations: a piece of furniture",
          "example": "We need new furniture for the living room."
        },
        {
          "id": "f7",
          "front": "DISCOUNT 💰",
          "back": "Discount on a purchase. Collocations: get / offer / give a discount",
          "example": "They offered me a 20% discount."
        },
        {
          "id": "f8",
          "front": "PROMOTION 📈",
          "back": "Ascenso laboral. Collocations: get / earn a promotion",
          "example": "She got a promotion to manager."
        },
        {
          "id": "f9",
          "front": "PRESCRIPTION 💊",
          "back": "Prescription. Collocations: write / fill a prescription",
          "example": "The doctor wrote a prescription for antibiotics."
        },
        {
          "id": "f10",
          "front": "BARGAIN 🏷️",
          "back": "Ganga, buen precio. Collocations: find / get a bargain",
          "example": "I found a real bargain at the market."
        },
        {
          "id": "f11",
          "front": "RESIGN ✋",
          "back": "Quit a job. Collocations: resign from a position",
          "example": "He decided to resign from his job."
        },
        {
          "id": "f12",
          "front": "REFUND 💵",
          "back": "Reembolso. Collocations: ask for / get a refund",
          "example": "I'd like to ask for a refund, please."
        }
      ]
    }
  },
