  {
    "id": "m10-ch2-quiz",
    "type": "quiz",
    "title": "What Word Do You Need?",
    "description": "Choose the correct word for each everyday situation.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "You have a headache. You need to take ___.",
          "options": [
            "medicine",
            "furniture",
            "a meeting",
            "homework"
          ],
          "correct": 0,
          "explanation": "Take medicine = take medicine. It is the correct placement."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "I need to ___ an appointment with the dentist.",
          "correct": "make",
          "explanation": "Make an appointment = make/schedule an appointment."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "Your project is due on Friday. Friday is the ___.",
          "options": [
            "receipt",
            "bargain",
            "deadline",
            "symptom"
          ],
          "correct": 2,
          "explanation": "Deadline = deadline."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "You want to return a shirt. You need the ___.",
          "options": [
            "prescription",
            "discount",
            "receipt",
            "salary"
          ],
          "correct": 2,
          "explanation": "Receipt = receipt. You need it for returns."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "Every morning I ___ a shower before work.",
          "correct": "take",
          "explanation": "Take a shower = take a shower (placement with take)."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "The person who works with you at the office is your ___.",
          "options": [
            "salary",
            "colleague",
            "deadline",
            "promotion"
          ],
          "correct": 1,
          "explanation": "Colleague = co-worker."
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "\"Don't forget to ___ the bed before you leave!\"",
          "options": [
            "do",
            "take",
            "have",
            "make"
          ],
          "correct": 3,
          "explanation": "Make the bed = make the bed."
        },
        {
          "id": "q8",
          "type": "fill-blank",
          "question": "She got a 30% ___ on the dress. It was very cheap!",
          "correct": "discount",
          "explanation": "Discount = descuento."
        },
        {
          "id": "q9",
          "type": "multiple-choice",
          "question": "When you feel sick, you should describe your ___ to the doctor.",
          "options": [
            "receipts",
            "deadlines",
            "symptoms",
            "bargains"
          ],
          "correct": 2,
          "explanation": "Symptoms = symptoms. You describe what you feel to the doctor."
        },
        {
          "id": "q10",
          "type": "fill-blank",
          "question": "I ___ homework every evening after school.",
          "correct": "do",
          "explanation": "Do homework = do homework (collocation with do)."
        }
      ]
    }
  },
