        },
        {
          "id": "f2",
          "front": "in-for-MA-tion ℹ️",
          "back": "Accent on the 3rd syllable. Rule: words in -tion → accent on previous syllable.",
          "example": "I need some information about the course."
        },
        {
          "id": "f3",
          "front": "fan-TAS-tic ⭐",
          "back": "Accent on the 2nd syllable. Rule: words in -ic → accent on previous syllable.",
          "example": "The concert was fantastic!"
        },
        {
          "id": "f4",
          "front": "AIR-port ✈️",
          "back": "Accent on the 1st syllable. Rule: compound nouns → accent on first element.",
          "example": "We arrived at the airport early."
        },
        {
          "id": "f5",
          "front": "e-co-NO-mic 💰",
          "back": "Accent on the 3rd syllable. Rule: words in -ic → accent on previous syllable.",
          "example": "The economic situation is improving."
        },
        {
          "id": "f6",
          "front": "u-ni-VER-si-ty 🎓",
          "back": "Accent on the 3rd syllable. Pattern: ooOoo.",
          "example": "She goes to university every day."
        },
        {
          "id": "f7",
          "front": "FOOT-ball ⚽",
          "back": "Accent on the 1st syllable. Rule: compound nouns → accent on first element.",
          "example": "Do you want to play football?"
        },
        {
          "id": "f8",
          "front": "com-PU-ter 💻",
          "back": "Accent on the 2nd syllable. Pattern: oOo.",
          "example": "I use my computer every day."
        },
        {
          "id": "f9",
          "front": "te-le-VI-sion 📺",
          "back": "Accent on the 3rd syllable. Rule: words in -sion → accent on previous syllable.",
          "example": "There's nothing good on television."
        },
        {
          "id": "f10",
          "front": "PHO-to-graph 📷",
          "back": "Accent on the 1st syllable. Pattern: Ooo. Note: changes in photography and photographic.",
          "example": "This is a beautiful photograph."
        }
      ]
    }
