    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "The intonation goes UP at the end: \"You're coming?\" — The speaker is...",
          "options": [
            "Making a statement",
            "Asking a yes/no question",
            "Giving an order",
            "Making a list"
          ],
          "correct": 1,
          "explanation": "Rising intonation at the end = yes/no question."
        },
        {
          "id": "q2",
          "type": "multiple-choice",
          "question": "The intonation goes DOWN at the end: \"I like chocolate.\" — This is a...",
          "options": [
            "Question",
            "Statement",
            "Request",
            "Surprise"
          ],
          "correct": 1,
          "explanation": "Falling intonation = affirmation."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "Which syllable is stressed in \"photograph\"?",
          "options": [
            "PHO (1st)",
            "to (2nd)",
            "graph (3rd)"
          ],
          "correct": 0,
          "explanation": "PHO-to-graph: the stress falls on the first syllable."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "Which syllable is stressed in \"photography\"?",
          "options": [
            "pho (1st)",
            "TO (2nd)",
            "gra (3rd)",
            "phy (4th)"
          ],
          "correct": 1,
          "explanation": "pho-TO-gra-phy: the stress moves to the second syllable."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "In the word \"information\", the stress falls on the ___ syllable. (first/second/third)",
          "correct": "third",
          "explanation": "in-for-MA-tion: the third syllable has the accent (rule: -tion)."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "\"I bought apples↗️, oranges↗️, and bananas↘️\" — This pattern is used for...",
          "options": [
            "Questions",
            "Statements",
            "Lists",
            "Surprises"
          ],
          "correct": 2,
          "explanation": "Ascending-ascending-descending pattern = enumeration/list."
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "In \"I WANT to GO to the PARK\", which words are stressed?",
          "options": [
            "I, to, the",
            "WANT, GO, PARK",
            "want, to, park",
            "All words equally"
          ],
          "correct": 1,
          "explanation": "Content words are stressed: WANT, GO, PARK."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "The intonation falls then rises: \"I'm not sure...\" — The speaker feels...",
          "options": [
            "Certain",
            "Angry",
            "Uncertain / polite",
            "Happy"
          ],
          "correct": 2,
          "explanation": "Fall-rise = uncertainty or politeness."
        },
        {
          "id": "q9",
          "type": "fill-blank",
          "question": "English is a ___-timed language. (stress/syllable)",
          "correct": "stress",
          "explanation": "English is stress-timed: the time between accents is regular."
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "Where is the stress in \"airport\" (compound noun)?",
          "options": [
            "AIR-port",
            "air-PORT"
          ],
          "correct": 0,
          "explanation": "Compound nouns: accent on the first element → AIR-port."
        }
      ]
    }
  },
