[
  {
    "id": "m6-ch5-flash",
    "type": "flashcard",
    "title": "Direct → Reported",
    "description": "Convert direct statements into indirect speech.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "\"I am happy,\" she said.",
          "back": "She said (that) she was happy.",
          "example": "am → was."
        },
        {
          "id": "c2",
          "front": "\"I like chocolate,\" he said.",
          "back": "He said (that) he liked chocolate.",
          "example": "like → liked."
        },
        {
          "id": "c3",
          "front": "\"I am working,\" she told me.",
          "back": "She told me (that) she was working.",
          "example": "am working → was working."
        },
        {
          "id": "c4",
          "front": "\"I have finished,\" he said.",
          "back": "He said (that) he had finished.",
          "example": "have finished → had finished."
        },
        {
          "id": "c5",
          "front": "\"I went to Paris,\" she said.",
          "back": "She said (that) she had gone to Paris.",
          "example": "went → had gone."
        },
        {
          "id": "c6",
          "front": "\"I will help you,\" he told me.",
          "back": "He told me (that) he would help me.",
          "example": "will → would, you → me."
        },
        {
          "id": "c7",
          "front": "\"I can swim,\" she said.",
          "back": "She said (that) she could swim.",
          "example": "can → could."
        },
        {
          "id": "c8",
          "front": "\"We are leaving today,\" they said.",
          "back": "They said (that) they were leaving that day.",
          "example": "are → were, today → that day."
        }
      ]
    }
  },
  {
    "id": "m6-ch5-match",
    "type": "word-match",
    "title": "Time Backshift",
    "description": "Match the direct tense with its reported form.",
    "props": {
      "pairs": [
        {
          "left": "am / is",
          "right": "was"
        },
        {
          "left": "like / play (present)",
          "right": "liked / played (past)"
        },
        {
          "left": "am working (cont.)",
          "right": "was working"
        },
        {
          "left": "have finished (perf.)",
          "right": "had finished"
        },
        {
          "left": "will",
          "right": "would"
        },
        {
          "left": "can",
          "right": "could"
        },
        {
          "left": "went (past)",
          "right": "had gone (past perf.)"
        }
      ]
    }
  },
  {
    "id": "m6-ch5-sentence",
    "type": "sentence-builder",
    "title": "Report what they said",
    "description": "Order to form sentences in indirect speech.",
    "props": {
      "sentences": [
        {
          "prompt": "\"Estoy feliz\" — ella dijo:",
          "words": [
            "She",
            "said",
            "she",
            "was",
