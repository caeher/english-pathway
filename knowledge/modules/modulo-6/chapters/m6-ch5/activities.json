            "he",
            "liked",
            "chocolate"
          ],
          "correct": "He told me he liked chocolate"
        },
        {
          "prompt": "\"I will help you\" — he said:",
          "words": [
            "He",
            "said",
            "he",
            "would",
            "help",
            "me"
          ],
          "correct": "He said he would help me"
        },
        {
          "prompt": "\"Puedo nadar\" — ella dijo:",
          "words": [
            "She",
            "said",
            "she",
            "could",
            "swim"
          ],
          "correct": "She said she could swim"
        },
        {
          "prompt": "\"I went to Paris\" — she said:",
          "words": [
            "She",
            "said",
            "she",
            "had",
            "gone",
            "to",
            "Paris"
          ],
          "correct": "She said she had gone to Paris"
        }
      ]
    }
  },
  {
    "id": "m6-ch5-quiz",
    "type": "quiz",
    "title": "Quiz: Reported Speech (Statements)",
    "description": "Demonstrate your mastery of indirect speech.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "\"I am happy,\" she said. → She said she ___ happy.",
          "options": [
            "is",
            "was",
            "has been",
            "were"
          ],
          "correct": 1,
          "explanation": "am → was (backshift)."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "\"I like chocolate,\" he said. → He said he ___ chocolate.",
          "correct": "liked",
          "explanation": "like → liked."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "\"I will help you,\" he said. → He said he ___ help me.",
          "options": [
            "will",
            "would",
            "could",
            "should"
          ],
          "correct": 1,
          "explanation": "will → would."
        },
        {
          "id": "q4",
          "type": "fill-blank",
          "question": "\"I can swim,\" she said. → She said she ___ swim.",
          "correct": "could",
          "explanation": "can → could."
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "She ___ me she was happy. (correct verb)",
          "options": [
            "said",
            "told",
            "said to",
            "tells"
          ],
          "correct": 1,
          "explanation": "told + person (told me)."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "He ___ he liked chocolate. (no person follows)",
          "options": [
            "told",
            "said",
            "told me",
            "say"
          ],
          "correct": 1,
          "explanation": "said (no person after said)."
        },
        {
          "id": "q7",
          "type": "fill-blank",
          "question": "\"I went to Paris.\" → She said she ___ gone to Paris.",
          "correct": "had",
          "explanation": "went → had gone (past → past perfect)."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "\"I will call you tomorrow.\" → He said he would call me ___.",
          "options": [
            "tomorrow",
            "the next day",
            "yesterday",
            "today"
          ],
          "correct": 1,
          "explanation": "tomorrow → the next day."
        }
      ]
    }
  },
