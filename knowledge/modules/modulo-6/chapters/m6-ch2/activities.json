            "x": 30,
            "y": 60,
            "width": 640,
            "height": 50,
            "fill": "#bfdbfe",
            "label": "📏 If + PRESENT SIMPLE, WILL + base verb",
            "labelEn": "If it RAINS, I WILL stay home. (I'LL stay home)"
