            "id": "order1",
            "type": "rect",
            "x": 30,
            "y": 200,
            "width": 310,
            "height": 50,
            "fill": "#e0e7ff",
            "label": "📝 If first → COMMA",
            "labelEn": "IF it rains, I'll stay home."
          },
          {
            "id": "order2",
            "type": "rect",
            "x": 360,
            "y": 200,
            "width": 310,
            "height": 50,
            "fill": "#fce7f3",
            "label": "📝 Result first → NO comma",
            "labelEn": "I'll stay home if it rains."
          },
          {
            "id": "neg",
            "type": "rect",
            "x": 30,
            "y": 270,
            "width": 310,
