            "id": "unless",
            "type": "rect",
            "x": 360,
            "y": 270,
            "width": 310,
            "height": 50,
            "fill": "#ccfbf1",
            "label": "🔑 Unless = If not",
            "labelEn": "UNLESS you study, you won't pass."
