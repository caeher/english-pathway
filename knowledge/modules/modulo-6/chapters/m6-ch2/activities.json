  {
    "id": "m6-ch2-flash",
    "type": "flashcard",
    "title": "First Conditional: Práctica",
    "description": "Forma oraciones con el primer condicional.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "If it ___ (rain), I ___ (stay) home.",
          "back": "If it rains, I will stay home. (I'll stay home.)",
          "example": "If + present simple, will + base verb."
        },
        {
          "id": "c2",
          "front": "If you ___ (study) hard, you ___ (pass).",
          "back": "If you study hard, you will pass. (you'll pass.)",
          "example": "Real possibility."
        },
        {
          "id": "c3",
          "front": "If she ___ (not hurry), she ___ (be) late.",
          "back": "If she doesn't hurry, she will be late.",
          "example": "Negative if clause: doesn't + base verb."
        },
        {
          "id": "c4",
          "front": "I ___ (help) you if you ___ (ask) me.",
          "back": "I will help you if you ask me. (I'll help you)",
          "example": "Result first = no comma."
        },
        {
          "id": "c5",
          "front": "If they ___ (not come), we ___ (start) without them.",
          "back": "If they don't come, we will start without them.",
          "example": "Negative condition."
        },
        {
          "id": "c6",
          "front": "___ you study, you won't pass. (if not)",
          "back": "Unless you study, you won't pass.",
          "example": "Unless = if not."
        },
        {
          "id": "c7",
          "front": "If you finish early, you ___ (can / leave).",
          "back": "If you finish early, you can leave.",
          "example": "Can instead of will = permission."
        },
        {
          "id": "c8",
          "front": "If it rains, we ___ (might / stay) home.",
          "back": "If it rains, we might stay home.",
          "example": "Might = possibility, less certain than will."
        }
      ]
    }
  },
