  {
    "id": "m6-ch2-quiz",
    "type": "quiz",
    "title": "Quiz: First Conditional",
    "description": "Demuestra tu dominio del primer condicional.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "\"If it ___, I'll stay home.\"",
          "options": [
            "will rain",
            "rains",
            "rained",
            "is raining"
          ],
          "correct": 1,
          "explanation": "If clause = present simple, not will."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "\"If you study hard, you ___ pass.\"",
          "correct": "will",
          "explanation": "Result clause: will + base verb."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "\"If she ___ hurry, she'll be late.\"",
          "options": [
            "doesn't",
            "won't",
            "didn't",
            "isn't"
          ],
          "correct": 0,
          "explanation": "If clause negative: doesn't + base verb."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "\"___ you study, you won't pass.\" (= If you don't study)",
          "options": [
            "Unless",
            "If",
            "When",
            "Because"
          ],
          "correct": 0,
          "explanation": "Unless = if not."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "\"I'll help you ___ you ask me.\"",
          "correct": "if",
          "explanation": "if introduces the condition."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "Which is CORRECT?",
          "options": [
            "If it rains, I'll stay home.",
            "If it will rain, I'll stay home.",
            "If it rained, I will stay home.",
            "If it rain, I'll stay home."
          ],
          "correct": 0,
          "explanation": "If + present simple, will + base verb."
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "\"If you finish early, you ___ leave.\" (permission)",
          "options": [
            "will",
            "can",
            "would",
            "could"
          ],
          "correct": 1,
          "explanation": "Can = permission in result clause."
        },
        {
          "id": "q8",
          "type": "fill-blank",
          "question": "\"If it rains, we ___ stay home.\" (possibility, less sure)",
          "correct": "might",
          "explanation": "Might = may = less certain possibility."
        }
      ]
    }
