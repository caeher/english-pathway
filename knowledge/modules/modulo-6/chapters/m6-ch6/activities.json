[
  {
    "id": "m6-ch6-flash",
    "type": "flashcard",
    "title": "Reported + Phrasal Verbs",
    "description": "Reported questions, commands and phrasal verbs.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "\"Do you like pizza?\" he asked.",
          "back": "He asked me if I liked pizza.",
          "example": "Yes/No → asked if."
        },
        {
          "id": "c2",
          "front": "\"Where do you live?\" she asked.",
          "back": "She asked me where I lived.",
          "example": "Wh: no inversion."
        },
        {
          "id": "c3",
          "front": "\"Open the door,\" she said.",
          "back": "She told me to open the door.",
          "example": "Order: told + to."
        },
        {
          "id": "c4",
          "front": "\"Don't touch that,\" he said.",
          "back": "He told me not to touch that.",
          "example": "Negative: not to."
        },
        {
          "id": "c5",
          "front": "get up",
          "back": "levantarse",
          "example": "I get up at 7."
        },
        {
          "id": "c6",
          "front": "look for / look after",
          "back": "buscar / cuidar",
          "example": "I'm looking for my keys. She looks after her brother."
        },
        {
          "id": "c7",
          "front": "give up / find out",
          "back": "rendirse / descubrir",
          "example": "Don't give up! I found out the truth."
        }
      ]
    }
  },
