  {
    "id": "m5-ch2-flash",
    "type": "flashcard",
    "title": "¿Pasado Simple o Presente Perfecto?",
    "description": "Decide cuál usar y por qué.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "I ___ (visit) Paris last year.",
          "back": "I visited Paris last year.",
          "example": "Past Simple: \"last year\" = specific time."
        },
        {
          "id": "c2",
          "front": "I ___ (visit) Paris. (alguna vez)",
          "back": "I have visited Paris.",
          "example": "Present Perfect: no specific time mentioned."
        },
        {
          "id": "c3",
          "front": "She ___ (see) the movie yesterday.",
          "back": "She saw the movie yesterday.",
          "example": "Past Simple: \"yesterday\" = specific time."
        },
        {
          "id": "c4",
          "front": "___ you ever ___ (eat) sushi?",
          "back": "Have you ever eaten sushi?",
          "example": "Present Perfect: \"ever\" = alguna vez."
        },
        {
          "id": "c5",
          "front": "He ___ (go) to Japan in 2019.",
          "back": "He went to Japan in 2019.",
          "example": "Past Simple: \"in 2019\" = specific time."
        },
        {
          "id": "c6",
          "front": "They ___ (live) here since 2018.",
          "back": "They have lived here since 2018.",
          "example": "Present Perfect: \"since\" = still now."
        },
        {
          "id": "c7",
          "front": "I ___ (finish) the homework already.",
          "back": "I have already finished the homework.",
          "example": "Present Perfect: \"already\" = ya."
        },
        {
          "id": "c8",
          "front": "We ___ (buy) a car two days ago.",
          "back": "We bought a car two days ago.",
          "example": "Past Simple: \"two days ago\" = specific time."
        },
        {
          "id": "c9",
          "front": "I ___ (work) here for five years.",
          "back": "I have worked here for five years.",
          "example": "Present Perfect: \"for\" = still now."
        },
        {
          "id": "c10",
          "front": "She ___ (just / arrive).",
          "back": "She has just arrived.",
          "example": "Present Perfect: \"just\" = acabar de."
        }
      ]
    }
  },
