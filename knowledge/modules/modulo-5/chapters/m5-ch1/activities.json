[
  {
    "id": "m5-ch1-flash",
    "type": "flashcard",
    "title": "Present Perfect: Conjugation",
    "description": "Practice forming the present perfect.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "I / visit / Paris",
          "back": "I have visited Paris. / I've visited Paris.",
          "example": "Regular: visit → visited."
        },
        {
          "id": "c2",
          "front": "She / see / that movie",
          "back": "She has seen that movie. / She's seen that movie.",
          "example": "Irregular: see → seen."
        },
        {
          "id": "c3",
          "front": "They / eat / sushi",
          "back": "They have eaten sushi. / They've eaten sushi.",
          "example": "Irregular: eat → eaten."
        },
        {
          "id": "c4",
          "front": "He / be / to Japan",
          "back": "He has been to Japan. / He's been to Japan.",
          "example": "Irregular: be → been."
        },
        {
          "id": "c5",
          "front": "I / never / fly",
          "back": "I have never flown.",
          "example": "Irregular: fly → flown. \"never\" before participle."
        },
        {
          "id": "c6",
          "front": "you / ever / speak / to her?",
          "back": "Have you ever spoken to her?",
          "example": "Irregular: speak → spoken."
        },
        {
          "id": "c7",
          "front": "I / just / arrive",
          "back": "I have just arrived. / I've just arrived.",
          "example": "\"just\" = finish."
        },
        {
          "id": "c8",
          "front": "She / already / finish",
          "back": "She has already finished. / She's already finished.",
          "example": "\"already\" before participle."
        },
        {
          "id": "c9",
          "front": "They / not / do / it / yet",
          "back": "They haven't done it yet.",
          "example": "Irregular: do → done. \"yet\" at end."
        },
        {
          "id": "c10",
          "front": "He / write / three books",
          "back": "He has written three books.",
          "example": "Irregular: write → written."
        },
        {
          "id": "c11",
          "front": "I / buy / a new car",
          "back": "I have bought a new car.",
          "example": "Irregular: buy → bought."
        },
        {
          "id": "c12",
          "front": "you / take / the exam / yet?",
          "back": "Have you taken the exam yet?",
          "example": "Irregular: take → taken."
        }
      ]
    }
  },
