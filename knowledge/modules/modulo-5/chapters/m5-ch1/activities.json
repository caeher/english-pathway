  {
    "id": "m5-ch1-quiz",
    "type": "quiz",
    "title": "Quiz: Presente Perfecto",
    "description": "Demonstrate your mastery of the present perfect.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "\"I ___ (visit) Paris.\" (present perfect)",
          "options": [
            "visited",
            "have visited",
            "has visited",
            "visiting"
          ],
          "correct": 1,
          "explanation": "I have visited (I/you/we/they → have)."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "\"She ___ (see) that movie.\" (present perfect)",
          "correct": "has seen",
          "explanation": "She has seen (he/she/it → has)."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "\"Have you ___ been to Japan?\"",
          "options": [
            "already",
            "ever",
            "yet",
            "just"
          ],
          "correct": 1,
          "explanation": "\"ever\" in questions = alguna vez."
        },
        {
          "id": "q4",
          "type": "fill-blank",
          "question": "\"I have ___ eaten sushi.\" (nunca)",
          "correct": "never",
          "explanation": "never = nunca."
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "\"I haven't finished ___.\"",
          "options": [
            "already",
            "ever",
            "yet",
            "just"
          ],
          "correct": 2,
          "explanation": "\"yet\" at the end of negatives/questions."
        },
        {
          "id": "q6",
          "type": "fill-blank",
          "question": "\"go\" → past participle: ___",
          "correct": "gone",
          "explanation": "go → went → gone."
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "\"eat\" → past participle: ___",
          "options": [
            "ate",
            "eaten",
            "eat",
            "eating"
          ],
          "correct": 1,
          "explanation": "eat → ate → eaten."
        },
        {
          "id": "q8",
          "type": "fill-blank",
          "question": "\"I've ___ arrived.\" (finish)",
          "correct": "just",
          "explanation": "just = finish (very recently)."
        },
        {
          "id": "q9",
          "type": "multiple-choice",
          "question": "Which is WRONG?",
          "options": [
            "I've visited Paris.",
            "I've visited Paris last year.",
            "I visited Paris last year.",
            "She's been to Japan."
          ],
          "correct": 1,
          "explanation": "With specific time (last year) → Past Simple, not Present Perfect."
        },
        {
          "id": "q10",
          "type": "fill-blank",
          "question": "\"She ___ already ___ .\" (finish)",
          "correct": "has finished",
          "explanation": "She has already finished / She's already finished."
        }
      ]
    }
  },
