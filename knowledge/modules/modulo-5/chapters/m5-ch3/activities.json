[
  {
    "id": "m5-ch3-flash",
    "type": "flashcard",
    "title": "Past Perfect: Conjugation",
    "description": "Practice forming the past perfect correctly.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "When I arrived, she ___ (leave).",
          "back": "When I arrived, she had left.",
          "example": "She left BEFORE I arrived."
        },
        {
          "id": "c2",
          "front": "They ___ (finish) dinner before the movie started.",
          "back": "They had finished dinner before the movie started.",
          "example": "Finished FIRST, then movie started."
        },
        {
          "id": "c3",
          "front": "I ___ never ___ (see) snow until I visited Canada.",
          "back": "I had never seen snow until I visited Canada.",
          "example": "First experience: never...before."
        },
        {
          "id": "c4",
          "front": "By the time we got there, the train ___ (leave).",
          "back": "By the time we got there, the train had left.",
          "example": "The train left BEFORE we arrived."
        },
        {
          "id": "c5",
          "front": "She ___ (not / eat) breakfast, so she was hungry.",
          "back": "She hadn't eaten breakfast, so she was hungry.",
          "example": "Negative: hadn't + past participle."
        },
        {
          "id": "c6",
          "front": "___ you ___ (do) your homework before class?",
          "back": "Had you done your homework before class?",
          "example": "Question: Had + subject + past participle?"
        },
        {
          "id": "c7",
          "front": "After he ___ (read) the book, he returned it.",
          "back": "After he had read the book, he returned it.",
          "example": "Read FIRST, then returned."
        },
        {
          "id": "c8",
          "front": "I ___ (already / buy) the tickets when she called.",
          "back": "I had already bought the tickets when she called.",
          "example": "Bought BEFORE she called."
        }
      ]
    }
  },
