[
  {
    "id": "m5-ch5-svg",
    "type": "svg-scene",
    "title": "Activa vs. Pasiva",
    "description": "Visualize how a sentence transforms from active to passive.",
    "props": {
      "scene": {
        "viewBox": "0 0 700 420",
        "bg": "#ecfeff",
        "items": [
          {
            "id": "title",
            "type": "rect",
            "x": 100,
            "y": 5,
            "width": 500,
            "height": 45,
            "fill": "#06b6d4",
            "label": "🔄 Passive Voice",
            "labelEn": "BE + past participle — focus on the action"
          },
          {
            "id": "active",
            "type": "rect",
            "x": 30,
            "y": 60,
            "width": 310,
            "height": 50,
            "fill": "#fde68a",
            "label": "🏃 Active Voice",
            "labelEn": "Subject DOES the action: The dog BIT the man."
          },
          {
            "id": "passive",
            "type": "rect",
            "x": 360,
            "y": 60,
            "width": 310,
            "height": 50,
            "fill": "#bfdbfe",
            "label": "🎯 Passive Voice",
            "labelEn": "Subject RECEIVES the action: The man WAS BITTEN."
          },
          {
            "id": "pres",
            "type": "rect",
            "x": 30,
            "y": 125,
            "width": 310,
            "height": 45,
            "fill": "#bbf7d0",
            "label": "📌 Present Simple",
            "labelEn": "Active: They MAKE cars. → Passive: Cars ARE MADE."
          },
          {
            "id": "past",
            "type": "rect",
            "x": 360,
            "y": 125,
            "width": 310,
            "height": 45,
            "fill": "#e0e7ff",
            "label": "📌 Past Simple",
            "labelEn": "Active: Someone STOLE it. → Passive: It WAS STOLEN."
          },
          {
            "id": "perf",
            "type": "rect",
            "x": 30,
            "y": 185,
            "width": 310,
            "height": 45,
            "fill": "#fce7f3",
            "label": "📌 Present Perfect",
            "labelEn": "Active: They'VE REPAIRED it. → Passive: It HAS BEEN REPAIRED."
          },
          {
            "id": "fut",
            "type": "rect",
            "x": 360,
            "y": 185,
            "width": 310,
            "height": 45,
            "fill": "#fef3c7",
            "label": "📌 Future Simple",
            "labelEn": "Active: They WILL BUILD it. → Passive: It WILL BE BUILT."
          },
          {
            "id": "prescont",
            "type": "rect",
            "x": 30,
            "y": 245,
            "width": 310,
            "height": 45,
            "fill": "#ccfbf1",
            "label": "📌 Present Continuous",
            "labelEn": "Active: They'RE BUILDING it. → Passive: It IS BEING BUILT."
          },
          {
            "id": "pastcont",
            "type": "rect",
            "x": 360,
            "y": 245,
            "width": 310,
            "height": 45,
            "fill": "#fecaca",
            "label": "📌 Past Continuous",
            "labelEn": "Active: They WERE CLEANING. → Passive: It WAS BEING CLEANED."
          },
          {
            "id": "by",
            "type": "rect",
            "x": 30,
            "y": 310,
            "width": 310,
            "height": 50,
            "fill": "#dbeafe",
            "label": "🔑 BY + agent",
            "labelEn": "The book was written BY J.K. Rowling. (who did it)"
          },
          {
            "id": "pattern",
            "type": "rect",
            "x": 360,
            "y": 310,
            "width": 310,
            "height": 50,
            "fill": "#dcfce7",
            "label": "📏 Pattern",
            "labelEn": "Subject + BE (conjugated) + Past Participle (+ by agent)"
          },
          {
            "id": "tip",
            "type": "rect",
            "x": 100,
            "y": 375,
            "width": 500,
            "height": 40,
            "fill": "#fef9c3",
            "label": "💡 When to use?",
            "labelEn": "When receiver is important, or we don't know who did it."
          }
        ]
      }
    }
  },
  {
    "id": "m5-ch5-flash",
    "type": "flashcard",
    "title": "From Active to Passive",
    "description": "Transform active sentences into passive ones.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "They make cars in Japan. (Present Simple)",
          "back": "Cars are made in Japan.",
          "example": "are + made (pp of make)."
        },
        {
          "id": "c2",
          "front": "Someone stole my bike. (Past Simple)",
          "back": "My bike was stolen.",
          "example": "was + stolen (pp of steal)."
        },
        {
          "id": "c3",
          "front": "They have repaired the road. (Pres. Perfect)",
          "back": "The road has been repaired.",
          "example": "has been + repaired."
        },
        {
          "id": "c4",
          "front": "They will build a bridge. (Future)",
          "back": "A bridge will be built.",
          "example": "will be + built (pp of build)."
        },
        {
          "id": "c5",
          "front": "They are building a house. (Pres. Continuous)",
          "back": "A house is being built.",
          "example": "is being + built."
        },
        {
          "id": "c6",
          "front": "They were cleaning the room. (Past Continuous)",
          "back": "The room was being cleaned.",
          "example": "was being + cleaned."
        },
        {
          "id": "c7",
          "front": "J.K. Rowling wrote the book. (Past Simple)",
          "back": "The book was written by J.K. Rowling.",
          "example": "was + written + by agent."
        },
        {
          "id": "c8",
          "front": "Millions of people speak English. (Pres. Simple)",
          "back": "English is spoken by millions of people.",
          "example": "is + spoken + by agent."
        },
        {
          "id": "c9",
          "front": "They will open the new store tomorrow. (Future)",
          "back": "The new store will be opened tomorrow.",
          "example": "will be + opened."
        },
        {
          "id": "c10",
          "front": "They have sold all the tickets. (Pres. Perfect)",
          "back": "All the tickets have been sold.",
          "example": "have been + sold."
        },
        {
          "id": "c11",
          "front": "The letter wasn't sent. (negative)",
          "back": "The letter wasn't sent. (was + not + pp)",
          "example": "Negative passive: be + not + pp."
        },
        {
          "id": "c12",
          "front": "Was the house built in 2020? (interrogative)",
          "back": "Was the house built in 2020?",
          "example": "Question: Be + subject + pp?"
        }
      ]
    }
  },
