    "description": "Test your mastery of the passive voice.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "\"They make cars in Japan.\" → Passive:",
          "options": [
            "Cars are making in Japan.",
            "Cars are made in Japan.",
            "Cars is made in Japan.",
            "Cars were made in Japan."
          ],
          "correct": 1,
          "explanation": "Present Simple passive: are + made."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "\"Someone stole my bike.\" → \"My bike ___ stolen.\"",
          "correct": "was",
          "explanation": "Past Simple passive: was + pp."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "\"They have repaired the road.\" → Passive:",
          "options": [
            "The road has been repaired.",
            "The road was repaired.",
            "The road is being repaired.",
            "The road has repaired."
          ],
          "correct": 0,
          "explanation": "Present Perfect passive: has been + pp."
        },
        {
          "id": "q4",
          "type": "fill-blank",
          "question": "\"A bridge ___ ___ built.\" (future passive)",
          "correct": "will be",
          "explanation": "Future passive: will be + pp."
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "\"A house ___ built.\" (present continuous passive)",
          "options": [
            "is being",
            "was being",
            "has been",
            "will be"
          ],
          "correct": 0,
          "explanation": "Pres. Continuous passive: is/are being + pp."
        },
        {
          "id": "q6",
          "type": "fill-blank",
          "question": "\"The book was written ___ J.K. Rowling.\"",
          "correct": "by",
          "explanation": "\"by\" introduces the agent."
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "When do we use passive?",
          "options": [
            "When the doer is more important.",
            "When the receiver is more important or doer is unknown.",
            "Always in formal writing.",
            "When talking about the future."
          ],
          "correct": 1,
          "explanation": "Passive focuses on the receiver or when doer is unknown."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "\"English ___ by millions.\" (present simple passive)",
          "options": [
            "is spoken",
            "was spoken",
            "speaks",
            "spoken"
          ],
          "correct": 0,
          "explanation": "Present Simple passive: is + spoken."
        },
        {
          "id": "q9",
          "type": "multiple-choice",
          "question": "\"The letter ___ sent yet.\" (negative, present perfect passive)",
          "options": [
            "hasn't been",
            "hasn't",
            "wasn't",
            "isn't been"
          ],
          "correct": 0,
          "explanation": "Present Perfect negative: hasn't/haven't been + pp."
        },
        {
          "id": "q10",
          "type": "fill-blank",
          "question": "\"___ the house built in 2020?\" (interrogative)",
          "correct": "Was",
          "explanation": "Past Simple passive question: Was + subject + pp?"
        }
      ]
    }
