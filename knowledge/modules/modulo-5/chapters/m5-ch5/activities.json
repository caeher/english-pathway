[
  {
    "id": "m5-ch5-flash",
    "type": "flashcard",
    "title": "From Active to Passive",
    "description": "Transform active sentences into passive ones.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "They make cars in Japan. (Present Simple)",
          "back": "Cars are made in Japan.",
          "example": "are + made (pp of make)."
        },
        {
          "id": "c2",
          "front": "Someone stole my bike. (Past Simple)",
          "back": "My bike was stolen.",
          "example": "was + stolen (pp of steal)."
        },
        {
          "id": "c3",
          "front": "They have repaired the road. (Pres. Perfect)",
          "back": "The road has been repaired.",
          "example": "has been + repaired."
        },
        {
          "id": "c4",
          "front": "They will build a bridge. (Future)",
          "back": "A bridge will be built.",
          "example": "will be + built (pp of build)."
        },
        {
          "id": "c5",
          "front": "They are building a house. (Pres. Continuous)",
          "back": "A house is being built.",
          "example": "is being + built."
        },
        {
          "id": "c6",
          "front": "They were cleaning the room. (Past Continuous)",
          "back": "The room was being cleaned.",
          "example": "was being + cleaned."
        },
        {
          "id": "c7",
          "front": "J.K. Rowling wrote the book. (Past Simple)",
          "back": "The book was written by J.K. Rowling.",
          "example": "was + written + by agent."
        },
        {
          "id": "c8",
          "front": "Millions of people speak English. (Pres. Simple)",
          "back": "English is spoken by millions of people.",
          "example": "is + spoken + by agent."
        },
        {
          "id": "c9",
          "front": "They will open the new store tomorrow. (Future)",
          "back": "The new store will be opened tomorrow.",
          "example": "will be + opened."
        },
        {
          "id": "c10",
          "front": "They have sold all the tickets. (Pres. Perfect)",
          "back": "All the tickets have been sold.",
          "example": "have been + sold."
        },
        {
          "id": "c11",
          "front": "The letter wasn't sent. (negative)",
          "back": "The letter wasn't sent. (was + not + pp)",
          "example": "Negative passive: be + not + pp."
        },
        {
          "id": "c12",
          "front": "Was the house built in 2020? (interrogative)",
          "back": "Was the house built in 2020?",
          "example": "Question: Be + subject + pp?"
        }
      ]
    }
  },
  {
    "id": "m5-ch5-match",
    "type": "word-match",
    "title": "Tiempo → Pasiva Pattern",
    "description": "Match the tense with its passive form.",
    "props": {
      "pairs": [
        {
          "left": "Present Simple",
          "right": "am/is/are + pp"
        },
        {
          "left": "Past Simple",
          "right": "was/were + pp"
        },
        {
          "left": "Present Perfect",
          "right": "has/have been + pp"
        },
        {
          "left": "Future Simple",
          "right": "will be + pp"
        },
        {
          "left": "Present Continuous",
          "right": "is/are being + pp"
        },
        {
          "left": "Past Continuous",
          "right": "was/were being + pp"
        }
      ]
    }
  },
