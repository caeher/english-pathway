          ],
          "correct": 1,
          "explanation": "write → wrote → written."
        },
        {
          "id": "q7",
          "type": "fill-blank",
          "question": "\"She has ___ (do) her homework.\"",
          "correct": "done",
          "explanation": "do → did → done."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "Which uses present participle?",
          "options": [
            "The house was built.",
            "I have seen it.",
            "She is swimming.",
            "The letter was written."
          ],
          "correct": 2,
          "explanation": "Continuous: be + -ing (present participle)."
        }
      ]
    }
