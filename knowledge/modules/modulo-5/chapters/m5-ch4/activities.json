        {
          "id": "q4",
          "type": "fill-blank",
          "question": "\"The car was ___ (steal).\"",
          "correct": "stolen",
          "explanation": "Passive: be + past participle."
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "Present participle form?",
          "options": [
            "base + -ed",
            "base + -ing",
            "had + base",
            "will + base"
          ],
          "correct": 1,
          "explanation": "Present participle = -ing."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "\"write\" → past participle?",
          "options": [
