          ],
          "correct": "a broken window"
        },
        {
          "prompt": "An interesting book:",
          "words": [
            "an",
            "interesting",
            "book"
          ],
          "correct": "an interesting book"
        }
      ]
    }
  },
  {
    "id": "m5-ch4-quiz",
    "type": "quiz",
    "title": "Quiz: Nature of Participles",
    "description": "Show that you understand what participles are.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "Are participles verb tenses?",
          "options": [
            "Yes, they are tenses.",
            "No, they are verb forms used in structures.",
            "Only past participle is.",
            "Only present participle is."
          ],
          "correct": 1,
          "explanation": "Participles are forms, not tenses."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "\"go\" → past participle?",
          "correct": "gone",
          "explanation": "go → went → gone."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "Which structure uses past participle?",
          "options": [
            "I am working (continuous)",
            "I have eaten (perfect)",
            "She is running (continuous)",
            "They are playing (continuous)"
          ],
          "correct": 1,
          "explanation": "Perfect = have + past participle."
        },
        {
          "id": "q4",
          "type": "fill-blank",
          "question": "\"The car was ___ (steal).\"",
          "correct": "stolen",
          "explanation": "Passive: be + past participle."
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "Present participle form?",
          "options": [
            "base + -ed",
            "base + -ing",
            "had + base",
            "will + base"
          ],
          "correct": 1,
          "explanation": "Present participle = -ing."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "\"write\" → past participle?",
          "options": [
            "wrote",
            "written",
            "writed",
            "writing"
          ],
          "correct": 1,
          "explanation": "write → wrote → written."
        },
        {
          "id": "q7",
          "type": "fill-blank",
          "question": "\"She has ___ (do) her homework.\"",
          "correct": "done",
          "explanation": "do → did → done."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "Which uses present participle?",
          "options": [
            "The house was built.",
            "I have seen it.",
            "She is swimming.",
            "The letter was written."
          ],
          "correct": 2,
          "explanation": "Continuous: be + -ing (present participle)."
        }
      ]
    }
  },
