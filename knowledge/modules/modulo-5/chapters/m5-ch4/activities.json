[
  {
    "id": "m5-ch4-flash",
    "type": "flashcard",
    "title": "Participios: Presente vs Pasado",
    "description": "Identifica cada forma y su uso.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "Are participles verb tenses?",
          "back": "NO! They are verb FORMS (shapes) used in structures.",
          "example": "Perfect = have + pp. Passive = be + pp."
        },
        {
          "id": "c2",
          "front": "Present participle form?",
          "back": "base + -ing: working, eating, running",
          "example": "Used in: continuous (am working), gerund (Swimming is fun)"
        },
        {
          "id": "c3",
          "front": "Past participle: regular?",
          "back": "base + -ed: worked, played, studied",
          "example": "Same as Past Simple for regular verbs."
        },
        {
          "id": "c4",
          "front": "go → past participle?",
          "back": "gone (irregular: go → went → gone)",
          "example": "I have gone. The money has gone."
        },
        {
          "id": "c5",
          "front": "eat → past participle?",
          "back": "eaten (eat → ate → eaten)",
          "example": "She has eaten. The food was eaten."
        },
        {
          "id": "c6",
          "front": "write → past participle?",
          "back": "written (write → wrote → written)",
          "example": "I have written. The book was written by her."
        },
        {
          "id": "c7",
          "front": "Continuous uses which participle?",
          "back": "Present participle (-ing): am/is/are + -ing",
          "example": "I am working. She was eating."
        },
        {
          "id": "c8",
          "front": "Passive uses which participle?",
          "back": "Past participle: be + pp (was stolen, is built)",
          "example": "The car was stolen. The house is being built."
        }
      ]
    }
  },
  {
