  {
    "id": "m5-ch6-quiz",
    "type": "quiz",
    "title": "Quiz: Pasiva Avanzada",
    "description": "Demonstrate your mastery of the advanced passive voice.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "\"They gave me a present.\" → Passive:",
          "options": [
            "I was given a present.",
            "A present was gave to me.",
            "Me was given a present.",
            "I have given a present."
          ],
          "correct": 0,
          "explanation": "Person as subject: I was given a present."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "\"You must do the homework.\" → \"The homework ___ ___ done.\"",
          "correct": "must be",
          "explanation": "Modal passive: must be + pp."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "\"The problem ___ fixed.\" (can)",
          "options": [
            "can be",
            "can been",
            "can is",
            "could been"
          ],
          "correct": 0,
          "explanation": "can + be + pp."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "Which is WRONG?",
          "options": [
            "The room should be cleaned.",
            "The accident was happened.",
            "I was born in 1990.",
            "It is said that he is rich."
          ],
          "correct": 1,
          "explanation": "\"happen\" is intransitive — cannot be passive."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "\"I ___ born in 1990.\"",
          "correct": "was",
          "explanation": "be born = was/were born."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "\"People say he is rich.\" → Impersonal passive:",
          "options": [
            "He says to be rich.",
            "It is said that he is rich.",
            "It says he is rich.",
            "He is saying to be rich."
          ],
          "correct": 1,
          "explanation": "It is said that... = impersonal passive."
        },
        {
          "id": "q7",
          "type": "fill-blank",
          "question": "\"This table is ___ of wood.\"",
          "correct": "made",
          "explanation": "be made of + material."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "\"The event ___ cancelled.\" (might)",
          "options": [
            "might be",
            "might is",
            "might been",
            "might being"
          ],
          "correct": 0,
          "explanation": "might + be + pp."
        },
        {
          "id": "q9",
          "type": "fill-blank",
          "question": "\"She is ___ for her kindness.\"",
          "correct": "known",
          "explanation": "be known for = be known by."
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "Which verb CANNOT be used in passive?",
          "options": [
            "make",
            "eat",
            "arrive",
            "build"
          ],
          "correct": 2,
          "explanation": "\"arrive\" is intransitive — no object."
        }
      ]
    }
  },
