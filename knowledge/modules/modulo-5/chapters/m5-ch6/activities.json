  {
    "id": "m5-ch6-flash",
    "type": "flashcard",
    "title": "Transformaciones Complejas",
    "description": "Practice the passive voice in advanced contexts.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "They gave me a present. (pasiva)",
          "back": "I was given a present. / A present was given to me.",
          "example": "Two objects: person or thing as subject."
        },
        {
          "id": "c2",
          "front": "You must do the homework. (pasiva)",
          "back": "The homework must be done.",
          "example": "Modal passive: modal + be + pp."
        },
        {
          "id": "c3",
          "front": "They can fix the problem. (pasiva)",
          "back": "The problem can be fixed.",
          "example": "can + be + fixed."
        },
        {
          "id": "c4",
          "front": "We should clean the room. (pasiva)",
          "back": "The room should be cleaned.",
          "example": "should + be + cleaned."
        },
        {
          "id": "c5",
          "front": "People say he is rich. (pasiva impersonal)",
          "back": "It is said that he is rich. / He is said to be rich.",
          "example": "Impersonal: It is said/believed/known that..."
        },
        {
          "id": "c6",
          "front": "Can? \"The accident happened.\"",
          "back": "❌ INCORRECTO. \"The accident happened.\"",
          "example": "\"happen\" is intransitive — cannot be passive."
        },
        {
          "id": "c7",
          "front": "This table / make / wood",
          "back": "This table is made of wood.",
          "example": "\"be made of\" = material."
        },
        {
          "id": "c8",
          "front": "I / born / 1990",
          "back": "I was born in 1990.",
          "example": "\"be born\" = nacer (always passive)."
        },
        {
          "id": "c9",
          "front": "She / know / for her kindness",
          "back": "She is known for her kindness.",
          "example": "\"be known for\" = be known by."
        },
        {
          "id": "c10",
          "front": "They might cancel the event. (pasiva)",
          "back": "The event might be cancelled.",
          "example": "might + be + cancelled."
        }
      ]
    }
  },
