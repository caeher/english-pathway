  {
    "id": "m12-ch4-flash",
    "type": "flashcard",
    "title": "Reducciones Esenciales",
    "description": "Learn each reduction with its full form, rule, and context of use.",
    "props": {
      "cards": [
        {
          "id": "f1",
          "front": "GONNA 🗣️",
          "back": "= going to. Just speak informally and casually. NEVER in formal writing.",
          "example": "I'm gonna call you later. (= I'm going to call you later.)"
        },
        {
          "id": "f2",
          "front": "WANNA 🗣️",
          "back": "= want to. Informal. It is used with \"I\", \"you\", \"we\", \"they\". NOT with \"he/she/it\".",
          "example": "I wanna go home. (= I want to go home.)"
        },
        {
          "id": "f3",
          "front": "GOTTA 🗣️",
          "back": "= got to / have got to. Informal obligation. Very common in the US.",
          "example": "I gotta leave now. (= I have got to leave now.)"
        },
        {
          "id": "f4",
          "front": "HAFTA 🗣️",
          "back": "= have to. Informal obligation. Alternative to \"gotta\".",
          "example": "You hafta try this restaurant. (= You have to try this restaurant.)"
        },
        {
          "id": "f5",
          "front": "LEMME 🗣️",
          "back": "= let me. Very casual. Informal request.",
          "example": "Lemme think about it. (= Let me think about it.)"
        },
        {
          "id": "f6",
          "front": "KINDA 🗣️",
          "back": "= kind of. It means \"something, a little.\" Soften what you say.",
          "example": "I'm kinda tired. (= I'm kind of tired.)"
        },
        {
          "id": "f7",
          "front": "DUNNO 🗣️",
          "back": "= don't know. Muy informal. A veces se escribe 'I dunno'.",
          "example": "I dunno what happened. (= I don't know what happened.)"
        },
        {
          "id": "f8",
          "front": "GIMME 🗣️",
          "back": "= give me. Muy casual/informal. Puede sonar demandante.",
          "example": "Gimme a break! (= Give me a break!)"
        },
        {
          "id": "f9",
          "front": "A LOTTA 🗣️",
          "back": "= a lot of. Informal. Cantidad grande.",
          "example": "There are a lotta people here. (= There are a lot of people here.)"
        },
        {
          "id": "f10",
          "front": "DON'TCHU / DONTCHA 🗣️",
          "back": "= don't you. Assimilation: /t/ + /y/ merge into /tʃ/ (\"ch\").",
          "example": "Don'tchu think so? (= Don't you think so?)"
        }
      ]
    }
  },
