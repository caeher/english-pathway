  {
    "id": "m12-ch4-quiz",
    "type": "quiz",
    "title": "What Did He Really Say?",
    "description": "Identify the full form of each reduction. Decodes natural speech.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "You hear: \"I'm gonna go.\" What is the full form?",
          "options": [
            "I am going to go",
            "I am gone go",
            "I gone to go",
            "I will go now"
          ],
          "correct": 0,
          "explanation": "gonna = going to. \"I'm gonna go\" = \"I am going to go.\""
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "Informal: \"I ___ leave now.\" (= I have got to leave now)",
          "correct": "gotta",
          "explanation": "gotta = got to / have got to. Expresses informal obligation."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "Which is appropriate for a JOB INTERVIEW?",
          "options": [
            "\"I wanna talk about my experience.\"",
            "\"I would like to discuss my experience.\"",
            "\"I'm gonna tell you stuff.\"",
            "\"Lemme explain.\""
          ],
          "correct": 1,
          "explanation": "Job interviews require formal language. \"I would like to...\" is the appropriate choice."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "You hear: \"I dunno what to do.\" \"Dunno\" means...",
          "options": [
            "do not",
            "don't know",
            "dinner",
            "done"
          ],
          "correct": 1,
          "explanation": "dunno = don't know. Very common in casual speech."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "\"___ see that movie!\" (= Let me see that movie!)",
          "correct": "Lemme",
          "explanation": "lemme = let me. Used in very casual speech."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "\"I'm kinda hungry.\" What does \"kinda\" mean?",
          "options": [
            "very",
            "kind of / somewhat",
            "not at all",
            "kindergarten"
          ],
          "correct": 1,
          "explanation": "kinda = kind of = something, a little. \"I'm kinda hungry\" = \"I'm kinda hungry.\""
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "\"She hafta go now.\" \"Hafta\" is the reduction of...",
          "options": [
            "half to",
            "has to",
            "have to",
            "happen to"
          ],
          "correct": 2,
          "explanation": "hafta = have to. Expresses obligation."
        },
        {
          "id": "q8",
          "type": "fill-blank",
          "question": "\"I ___ a pizza, please.\" (= I want to have a pizza — casual)",
          "correct": "wanna",
          "explanation": "wanna = want to. \"I wanna a pizza\" = \"I want a pizza\" (informal)."
        },
        {
          "id": "q9",
          "type": "multiple-choice",
          "question": "In \"turn it off\", how does this sound in connected speech?",
          "options": [
            "Turn. It. Off. (separate)",
            "\"tur-ni-toff\" (linked together)",
            "\"turn off it\"",
            "\"turning off\""
          ],
          "correct": 1,
          "explanation": "Linking: the words connect smoothly. \"turn it off\" → \"tur-ni-toff\"."
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "\"Gimme a break!\" What is the full form?",
          "options": [
            "Gym me a break",
            "Give me a break",
            "Got me a break",
            "Game me a break"
          ],
          "correct": 1,
          "explanation": "gimme = give me. Very casual/informal expression."
        }
      ]
    }
  },
