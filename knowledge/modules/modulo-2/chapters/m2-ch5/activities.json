    "title": "Quiz: Have, Has, Had",
    "description": "Show that you master the verb \"have\" in all its forms.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "\"She ___ a beautiful house.\"",
          "options": [
            "have",
            "has",
            "having",
            "haves"
          ],
          "correct": 1,
          "explanation": "He/She/It → has."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "\"I ___ a bicycle when I was 10.\"",
          "correct": "had",
          "explanation": "Past of have = had (all subjects)."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "\"They ___ (not/have) a car.\"",
          "options": [
            "don't have",
