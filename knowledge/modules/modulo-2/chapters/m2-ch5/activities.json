            "haven't",
            "isn't have"
          ],
          "correct": 0,
          "explanation": "They → don't have."
        },
        {
          "id": "q4",
          "type": "fill-blank",
          "question": "\"___ she have a sister?\" (present)",
          "correct": "Does",
          "explanation": "Does she have...?"
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "\"I ___ study for the exam.\" (obligation)",
          "options": [
            "have to",
            "has to",
            "had to",
            "having to"
          ],
          "correct": 0,
          "explanation": "I have to = I have to."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "\"She ___ work on weekends.\" (obligation)",
          "options": [
            "have to",
            "has to",
            "is to",
            "having to"
          ],
          "correct": 1,
          "explanation": "She has to = she has to."
        },
        {
          "id": "q7",
          "type": "fill-blank",
          "question": "\"We ___ breakfast at 7 every day.\"",
          "correct": "have",
          "explanation": "have breakfast = desayunar."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "\"He ___ (not/have) money yesterday.\"",
          "options": [
            "didn't have",
            "doesn't have",
            "hadn't have",
            "not had"
          ],
          "correct": 0,
          "explanation": "Past negative: didn't have."
        },
        {
          "id": "q9",
          "type": "fill-blank",
          "question": "\"I've ___ a new phone.\" (British English)",
          "correct": "got",
          "explanation": "have got = tener (I've got = I have)."
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "Which is CORRECT?",
          "options": [
            "She don't have a car.",
            "She doesn't has a car.",
            "She doesn't have a car.",
            "She haven't a car."
          ],
          "correct": 2,
          "explanation": "She doesn't have — doesn't + base form 'have'."
        }
      ]
    }
  },
