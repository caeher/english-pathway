[
  {
    "id": "m2-ch5-flash",
    "type": "flashcard",
    "title": "Uses of Have/Has/Had",
    "description": "Review all the forms and uses of the verb \"have.\"",
    "props": {
      "cards": [
        {
          "id": "h1",
          "front": "I ___ a dog. (present)",
          "back": "I HAVE a dog.",
          "example": "I/You/We/They → have."
        },
        {
          "id": "h2",
          "front": "She ___ blue eyes. (present)",
          "back": "She HAS blue eyes.",
          "example": "He/She/It → has."
        },
        {
          "id": "h3",
          "front": "I ___ a bicycle when I was 10. (past)",
          "back": "I HAD a bicycle.",
          "example": "All subjects use \"had\" in past."
        },
        {
          "id": "h4",
          "front": "I ___ (not/have) money. (present)",
          "back": "I DON'T HAVE money.",
          "example": "Negative: don't have / doesn't have."
        },
        {
          "id": "h5",
          "front": "She ___ (not/have) a car. (present)",
          "back": "She DOESN'T HAVE a car.",
          "example": "He/She/It → doesn't have."
        },
        {
          "id": "h6",
          "front": "They ___ (not/have) time. (past)",
          "back": "They DIDN'T HAVE time.",
          "example": "Past negative: didn't have."
        },
        {
          "id": "h7",
          "front": "___ you ___ a pen? (present)",
          "back": "DO you HAVE a pen?",
          "example": "Question: do/does + subject + have."
        },
        {
          "id": "h8",
          "front": "___ she ___ a sister? (present)",
          "back": "DOES she HAVE a sister?",
          "example": "He/She/It → Does + have."
        },
        {
          "id": "h9",
          "front": "I ___ study tonight. (obligation)",
          "back": "I HAVE TO study tonight.",
          "example": "have to = have to (obligation)."
        },
        {
          "id": "h10",
          "front": "She ___ work on Saturdays. (obligation)",
          "back": "She HAS TO work on Saturdays.",
          "example": "He/She/It → has to."
        },
        {
          "id": "h11",
          "front": "I've ___ a new phone. (British)",
          "back": "I've GOT a new phone.",
          "example": "have got = have (possession, British)."
        },
        {
          "id": "h12",
          "front": "have breakfast / have a shower",
          "back": "have + activity = DO an activity",
          "example": "have breakfast = desayunar, have a shower = ducharse."
        }
      ]
    }
  },
