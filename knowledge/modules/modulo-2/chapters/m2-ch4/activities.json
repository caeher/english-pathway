  {
    "id": "m2-ch4-quiz",
    "type": "quiz",
    "title": "Quiz: Negaciones y Preguntas",
    "description": "Show that you master denials and questions in the past tense.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "\"She ___ (not/go) to the party.\"",
          "options": [
            "didn't go",
            "didn't went",
            "not went",
            "doesn't go"
          ],
          "correct": 0,
          "explanation": "didn't + base verb: didn't go."
        },
        {
          "id": "q2",
          "type": "multiple-choice",
          "question": "\"___ you eat breakfast?\"",
          "options": [
            "Do",
            "Did",
            "Was",
            "Were"
          ],
          "correct": 1,
          "explanation": "Past question with Did + base verb."
        },
        {
          "id": "q3",
          "type": "fill-blank",
          "question": "\"___ he happy?\" (was)",
          "correct": "Was",
          "explanation": "Was he happy? — 'was' inverts with subject."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "\"They ___ (not/see) the movie.\"",
          "options": [
            "didn't see",
            "didn't saw",
            "not saw",
            "weren't see"
          ],
          "correct": 0,
          "explanation": "didn't + see (base form)."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "\"Did she ___ (buy) a new phone?\"",
          "correct": "buy",
          "explanation": "After Did, use base form: buy (not bought)."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "Correct short answer for \"Did you sleep well?\"",
          "options": [
            "Yes, I slept.",
            "Yes, I did.",
            "Yes, I do.",
            "Yes, I was."
          ],
          "correct": 1,
          "explanation": "Short answer: Yes, I did. / No, I didn't."
        },
        {
          "id": "q7",
          "type": "fill-blank",
          "question": "\"We ___ (not/be) at the meeting.\"",
          "correct": "weren't",
          "explanation": "were + not = weren't (no 'did' with was/were)."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "Which is WRONG?",
          "options": [
            "Did she go?",
            "She didn't go.",
            "Did she went?",
            "She went."
          ],
          "correct": 2,
          "explanation": "\"Did she went?\" is wrong. Correct: Did she GO?"
        },
        {
          "id": "q9",
          "type": "fill-blank",
          "question": "\"___ they at the park yesterday?\"",
          "correct": "Were",
          "explanation": "Were they at the park? — question with were."
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "\"He ___ (not/drive) to work yesterday.\"",
          "options": [
            "didn't drove",
            "didn't drive",
            "wasn't drove",
            "not drive"
          ],
          "correct": 1,
          "explanation": "didn't + base form: didn't drive."
        }
      ]
    }
  },
