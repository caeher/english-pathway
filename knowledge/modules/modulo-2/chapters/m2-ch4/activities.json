[
  {
    "id": "m2-ch4-flash",
    "type": "flashcard",
    "title": "Transformations in the Past",
    "description": "Practice turning affirmatives into negatives and questions.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "She went to the store. (negativa)",
          "back": "She didn't go to the store.",
          "example": "Usamos didn't + go (base form)."
        },
        {
          "id": "c2",
          "front": "I have ate lunch. (ask)",
          "back": "Did he eat lunch?",
          "example": "Did + he + eat (base form)."
        },
        {
          "id": "c3",
          "front": "They saw the movie. (negativa)",
          "back": "They didn't see the movie.",
          "example": "didn't + see (NOT saw)."
        },
        {
          "id": "c4",
          "front": "You bought a car. (ask)",
          "back": "Did you buy a car?",
          "example": "Did + you + buy (base form)."
        },
        {
          "id": "c5",
          "front": "I was at home. (negativa)",
          "back": "I wasn't at home.",
          "example": "was → wasn't (no 'did' needed)."
        },
        {
          "id": "c6",
          "front": "They were happy. (ask)",
          "back": "Were they happy?",
          "example": "were → Were they? (no 'did')."
        },
        {
          "id": "c7",
          "front": "She wrote a letter. (negativa)",
          "back": "She didn't write a letter.",
          "example": "didn't + write."
        },
        {
          "id": "c8",
          "front": "We flew to Madrid. (ask)",
          "back": "Did we fly to Madrid?",
          "example": "Did + we + fly."
        },
        {
          "id": "c9",
          "front": "He drove to work. (negativa)",
          "back": "He didn't drive to work.",
          "example": "didn't + drive."
        },
        {
          "id": "c10",
          "front": "Did you sleep well? (short answer yes)",
          "back": "Yes, I did.",
          "example": "Short answer: Yes, + subject + did."
        },
        {
          "id": "c11",
          "front": "Was she there? (short answer no)",
          "back": "No, she wasn't.",
          "example": "Short answer: No, + subject + wasn't."
        },
        {
          "id": "c12",
          "front": "Did they eat? (short answer no)",
          "back": "No, they didn't.",
          "example": "Short answer: No, + subject + didn't."
        }
      ]
    }
  },
