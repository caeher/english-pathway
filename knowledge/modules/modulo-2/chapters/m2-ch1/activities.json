[
  {
    "id": "m2-ch1-flash",
    "type": "flashcard",
    "title": "Verbs in the Present Simple",
    "description": "Master the conjugation and uses of the present simple.",
    "props": {
      "cards": [
        {
          "id": "ps1",
          "front": "I work / She works",
          "back": "Trabajo / Ella trabaja\n3rd person: add -s",
          "example": "I work at a bank. She works at a school."
        },
        {
          "id": "ps2",
          "front": "I play / He plays",
          "back": "Game / He plays\nVowel + y → add -s",
          "example": "I play tennis. He plays soccer."
        },
        {
          "id": "ps3",
          "front": "I watch / She watches",
          "back": "I look / She looks\nVerb in -ch → add -es",
          "example": "I watch TV. She watches movies."
        },
        {
          "id": "ps4",
          "front": "I study / He studies",
          "back": "Study / He studies\nConsonant + y → -ies",
          "example": "I study English. He studies math."
        },
        {
          "id": "ps5",
          "front": "I go / She goes",
          "back": "I go / She goes\nVerb in -o → add -es",
          "example": "I go to school. She goes to work."
        },
        {
          "id": "ps6",
          "front": "I don't work",
          "back": "No trabajo\nDO NOT + base verb",
          "example": "I don't work on Sundays."
        },
        {
          "id": "ps7",
          "front": "She doesn't work",
          "back": "Ella no trabaja\nDOES NOT + base verb (no -s!)",
          "example": "She doesn't work on weekends."
        },
        {
          "id": "ps8",
          "front": "Do you work?",
          "back": "Do you work?\nDO + subject + base verb?",
          "example": "Do you work here? — Yes, I do."
        },
        {
          "id": "ps9",
          "front": "Does she work?",
          "back": "Does she work?\nDOES + subject + base verb?",
          "example": "Does she work here? — No, she doesn't."
        },
        {
          "id": "ps10",
          "front": "Use: Habits",
          "back": "Actions you do regularly",
          "example": "I brush my teeth every morning."
        },
        {
          "id": "ps11",
          "front": "Uso: Verdades",
          "back": "Hechos universales",
          "example": "Water boils at 100°C."
        },
        {
          "id": "ps12",
          "front": "Uso: Estados",
          "back": "Situaciones permanentes",
          "example": "She lives in Madrid. He speaks Spanish."
        }
      ]
    }
  },
