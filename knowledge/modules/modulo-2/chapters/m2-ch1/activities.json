  {
    "id": "m2-ch1-quiz",
    "type": "quiz",
    "title": "Quiz: Presente Simple",
    "description": "Demonstrate your mastery of the present simple.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "fill-blank",
          "question": "She ___ (work) at a hospital.",
          "correct": "works",
          "explanation": "She works — add -s for 3rd person."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "He ___ (study) English every day.",
          "correct": "studies",
          "explanation": "Study → studies (consonant + y → ies)."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "\"She ___ coffee.\" (negative)",
          "options": [
            "don't drink",
            "doesn't drink",
            "doesn't drinks",
            "not drinks"
          ],
          "correct": 1,
          "explanation": "She doesn't drink — does not + base verb."
        },
        {
          "id": "q4",
          "type": "fill-blank",
          "question": "___ you like pizza? (question)",
          "correct": "Do",
          "explanation": "DO you like pizza?"
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "He ___ (go) to school every day.",
          "options": [
            "go",
            "goes",
            "gos",
            "going"
          ],
          "correct": 1,
          "explanation": "Go → goes (verb ending in -o → add -es)."
        },
        {
          "id": "q6",
          "type": "fill-blank",
          "question": "___ she speak Spanish? (question)",
          "correct": "Does",
          "explanation": "DOES she speak Spanish?"
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "Which sentence is correct?",
          "options": [
            "She don't like fish",
            "She doesn't likes fish",
            "She doesn't like fish",
            "She not like fish"
          ],
          "correct": 2,
          "explanation": "She doesn't like — doesn't + base verb."
        },
        {
          "id": "q8",
          "type": "fill-blank",
          "question": "I ___ (not/like) spiders.",
          "correct": "don't like",
          "explanation": "I don't like — do not + base verb."
        },
        {
          "id": "q9",
          "type": "multiple-choice",
          "question": "The present simple is used for…",
          "options": [
            "Actions happening now",
            "Past events",
            "Habits and routines",
            "Future plans"
          ],
          "correct": 2,
          "explanation": "Present simple = habits, routines, facts."
        },
        {
          "id": "q10",
          "type": "fill-blank",
          "question": "Water ___ (boil) at 100°C.",
          "correct": "boils",
          "explanation": "Water boils — universal truth in present simple."
        }
      ]
    }
