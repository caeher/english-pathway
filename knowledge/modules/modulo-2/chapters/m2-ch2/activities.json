  {
    "id": "m2-ch2-flash",
    "type": "flashcard",
    "title": "Adverbios y Rutinas",
    "description": "Master adverbs of frequency and their uses.",
    "props": {
      "cards": [
        {
          "id": "f1",
          "front": "ALWAYS (100%)",
          "back": "Always — all the time, without exception",
          "example": "I always drink water in the morning."
        },
        {
          "id": "f2",
          "front": "USUALLY (90%)",
          "back": "Generally — almost always",
          "example": "She usually walks to school."
        },
        {
          "id": "f3",
          "front": "OFTEN (70%)",
          "back": "often — frequently",
          "example": "We often go to the park on weekends."
        },
        {
          "id": "f4",
          "front": "SOMETIMES (50%)",
          "back": "Sometimes — from time to time",
          "example": "I sometimes eat pizza for dinner."
        },
        {
          "id": "f5",
          "front": "RARELY / SELDOM (10%)",
          "back": "Raramente — casi nunca",
          "example": "He rarely eats fast food."
        },
        {
          "id": "f6",
          "front": "NEVER (0%)",
          "back": "Never—ever",
          "example": "She never drinks soda."
        },
        {
          "id": "f7",
          "front": "every day",
          "back": "every day / every day",
          "example": "I exercise every day."
        },
        {
          "id": "f8",
          "front": "once a week",
          "back": "once a week",
          "example": "We have a meeting once a week."
        },
        {
          "id": "f9",
          "front": "twice a month",
          "back": "dos veces al mes",
          "example": "I visit my grandparents twice a month."
        },
        {
          "id": "f10",
          "front": "on Mondays",
          "back": "on Mondays (every Monday)",
          "example": "I have English class on Mondays."
        },
        {
          "id": "f11",
          "front": "Position: main verb",
          "back": "BEFORE the verb: I always EAT",
          "example": "I usually wake up at 7. She often reads."
        },
        {
          "id": "f12",
          "front": "Position: verb \"to be\"",
          "back": "AFTER \"to be\": She IS always happy",
          "example": "He is never late. They are usually tired."
        }
      ]
    }
  },
