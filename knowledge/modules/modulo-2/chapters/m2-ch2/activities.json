  {
    "id": "m2-ch2-quiz",
    "type": "quiz",
    "title": "Frequency Quiz",
    "description": "Test your knowledge of adverbs and routines.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "Which adverb means 0% frequency?",
          "options": [
            "always",
            "sometimes",
            "rarely",
            "never"
          ],
          "correct": 3,
          "explanation": "Never = 0% frequency."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "I ___ brush my teeth. (100%)",
          "correct": "always",
          "explanation": "Always = 100% frequency."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "Where does the adverb go? \"She ___ eats breakfast.\"",
          "options": [
            "After the verb",
            "Before the verb",
            "At the end",
            "Before the subject"
          ],
          "correct": 1,
          "explanation": "Adverbs go BEFORE the main verb."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "\"He is ___ late.\" Where goes the adverb?",
          "options": [
            "Before \"is\"",
            "After \"is\"",
            "At the beginning",
            "At the end"
          ],
          "correct": 1,
          "explanation": "Adverbs go AFTER \"to be\": He is always late."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "She ___ watches TV. She prefers reading. (10%)",
          "correct": "rarely",
          "explanation": "Rarely = 10% — almost never."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "Which is correct?",
          "options": [
            "I eat always breakfast",
            "I always eat breakfast",
            "Always I eat breakfast",
            "I eat breakfast always"
          ],
          "correct": 1,
          "explanation": "I always eat breakfast — adverb before main verb."
        },
        {
          "id": "q7",
          "type": "fill-blank",
          "question": "We ___ go to the beach. About half the time. (50%)",
          "correct": "sometimes",
          "explanation": "Sometimes = about 50% of the time."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "\"I exercise ___ a week.\" (two times)",
          "options": [
            "once",
            "twice",
            "three times",
            "every"
          ],
          "correct": 1,
          "explanation": "Twice a week = two times per week."
        },
        {
          "id": "q9",
          "type": "multiple-choice",
          "question": "Which is INCORRECT?",
          "options": [
            "I never smoke",
            "I don't never smoke",
            "I always study",
            "She usually cooks"
          ],
          "correct": 1,
          "explanation": "\"Never\" is already negative. Don't use \"don't\" with \"never\"."
        },
        {
          "id": "q10",
          "type": "fill-blank",
          "question": "She is ___ happy. She smiles all the time. (100%)",
          "correct": "always",
          "explanation": "She is always happy — after \"to be\"."
        }
      ]
    }
  },
