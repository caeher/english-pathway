          "back": "studied (regular, y→ied)",
          "example": "He studied for the exam."
        },
        {
          "id": "r4",
          "front": "eat → ?",
          "back": "ate (irregular)",
          "example": "She ate pizza last night."
        },
        {
          "id": "r5",
          "front": "stop → ?",
          "back": "stopped (regular, double p)",
          "example": "The bus stopped at the corner."
        },
        {
          "id": "r6",
          "front": "see → ?",
          "back": "saw (irregular)",
          "example": "I saw a beautiful sunset."
        },
        {
          "id": "r7",
          "front": "buy → ?",
          "back": "bought (irregular)",
          "example": "She bought a new dress."
        },
        {
          "id": "r8",
          "front": "want → ?",
          "back": "wanted (regular, /ɪd/)",
          "example": "I wanted a new phone."
        },
        {
          "id": "r9",
          "front": "think → ?",
          "back": "thought (irregular)",
          "example": "She thought about it."
        },
        {
          "id": "r10",
          "front": "swim → ?",
          "back": "swam (irregular)",
          "example": "They swam in the ocean."
        },
        {
          "id": "r11",
          "front": "read (past)",
          "back": "read (same spelling, /rɛd/)",
          "example": "I read a book yesterday."
        },
        {
          "id": "r12",
          "front": "Did you ___ ? (go)",
          "back": "Did you go? (base form after Did)",
          "example": "Never: Did you went?"
        }
      ]
    }
