  {
    "id": "m2-ch6-flash",
    "type": "flashcard",
    "title": "Presente vs Pasado",
    "description": "Identify when to use each tense.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "I ___ (work) every day.",
          "back": "I work every day. (Present — routine)",
          "example": "every day = present simple"
        },
        {
          "id": "c2",
          "front": "I ___ (work) yesterday.",
          "back": "I worked yesterday. (Past — completed)",
          "example": "yesterday = past simple"
        },
        {
          "id": "c3",
          "front": "She ___ (go) to school every day.",
          "back": "She goes to school every day.",
          "example": "every day = present, 3rd person + s"
        },
        {
          "id": "c4",
          "front": "She ___ (go) to the party last night.",
          "back": "She went to the party last night.",
          "example": "last night = past, went (irregular)"
        },
        {
          "id": "c5",
          "front": "Water ___ (boil) at 100°C.",
          "back": "Water boils at 100°C.",
          "example": "Universal fact = present simple"
        },
        {
          "id": "c6",
          "front": "The water ___ (boil) 5 minutes ago.",
          "back": "The water boiled 5 minutes ago.",
          "example": "ago = past simple"
        },
        {
          "id": "c7",
          "front": "He ___ (not/like) fish. (general)",
          "back": "He doesn't like fish.",
          "example": "General preference = present"
        },
        {
          "id": "c8",
          "front": "He ___ (not/like) the movie. (last night)",
          "back": "He didn't like the movie.",
          "example": "Last night = past"
        }
      ]
    }
  },
