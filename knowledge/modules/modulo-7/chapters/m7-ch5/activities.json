          "correct": 1,
          "explanation": "\"Agree\" is a verb — I agree. No \"am\" needed."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "\"There ___ many students in the class.\"",
          "options": [
            "is",
            "are",
            "has",
            "have"
          ],
          "correct": 1,
          "explanation": "there + plural → ARE."
        },
        {
          "id": "q9",
          "type": "fill-blank",
          "question": "\"I ___ go to the gym.\" (= always)",
          "correct": "always",
          "explanation": "Adverb of frequency before the main verb: I ALWAYS go."
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "\"She is ___ teacher.\"",
          "options": [
            "the",
            "a",
            "(nothing)",
            "one"
          ],
          "correct": 1,
          "explanation": "Professions need a/an: She is A teacher."
        }
      ]
    }
