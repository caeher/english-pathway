  {
    "id": "m7-ch5-flash",
    "type": "flashcard",
    "title": "Error → Corrección",
    "description": "Aprende la forma correcta de cada error común.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "❌ She have a car.",
          "back": "✅ She HAS a car.",
          "example": "3rd person singular → has/does/is"
        },
        {
          "id": "c2",
          "front": "❌ I have 25 years.",
          "back": "✅ I AM 25 years old.",
          "example": "Age uses \"be\", not \"have\"."
        },
        {
          "id": "c3",
          "front": "❌ I am agree.",
          "back": "✅ I agree.",
          "example": "\"Agree\" is a verb — no need for \"am\"."
        },
        {
          "id": "c4",
          "front": "❌ I like the music. (general)",
          "back": "✅ I like music.",
          "example": "No article for general/abstract nouns."
        },
        {
          "id": "c5",
          "front": "❌ It depends of you.",
          "back": "✅ It depends ON you.",
          "example": "\"Depend\" + ON (not \"of\")."
        },
        {
          "id": "c6",
          "front": "❌ I'm interesting in art.",
          "back": "✅ I'm INTERESTED in art.",
          "example": "-ed = how you feel / -ing = what causes the feeling"
        },
        {
          "id": "c7",
          "front": "❌ I go always to the gym.",
          "back": "✅ I always go to the gym.",
          "example": "Adverb of frequency goes BEFORE main verb."
        },
        {
          "id": "c8",
          "front": "❌ She is teacher.",
          "back": "✅ She is A teacher.",
          "example": "Always use a/an with professions after \"be\"."
        },
        {
          "id": "c9",
          "front": "❌ There is many people.",
          "back": "✅ There ARE many people.",
          "example": "Plural subject → \"are\"."
        },
        {
          "id": "c10",
          "front": "❌ He don't like it.",
          "back": "✅ He DOESN'T like it.",
          "example": "3rd person singular → does/doesn't."
        }
      ]
    }
  },
