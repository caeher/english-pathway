  {
    "id": "m7-ch3-flash",
    "type": "flashcard",
    "title": "Investment and Emphasis",
    "description": "Practice transforming normal sentences into emphatic ones.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "I have never seen such beauty. (inversion)",
          "back": "Never have I seen such beauty.",
          "example": "Never + have + subject."
        },
        {
          "id": "c2",
          "front": "She not only sings but also dances. (inversion)",
          "back": "Not only does she sing, but she also dances.",
          "example": "Not only + does + subject."
        },
        {
          "id": "c3",
          "front": "He hardly arrived when it rained. (inversion)",
          "back": "Hardly had he arrived when it started raining.",
          "example": "Hardly + had + subject."
        },
        {
          "id": "c4",
          "front": "I left and it started raining. (no sooner)",
          "back": "No sooner had I left than it started raining.",
          "example": "No sooner + had + subject + than."
        },
        {
          "id": "c5",
          "front": "We rarely see such talent. (inversion)",
          "back": "Rarely do we see such talent.",
          "example": "Rarely + do + subject."
        },
        {
          "id": "c6",
          "front": "John broke the window. (emphasis on John)",
          "back": "It was John who broke the window.",
          "example": "It was + focus + who/that."
        },
        {
          "id": "c7",
          "front": "I need more time. (emphasis on what)",
          "back": "What I need is more time.",
          "example": "What + subject + verb + is."
        },
        {
          "id": "c8",
          "front": "I did not know it would rain. (little)",
          "back": "Little did I know it would rain.",
          "example": "Little + did + subject + verb."
        }
      ]
    }
  },
