  {
    "id": "m7-ch2-flash",
    "type": "flashcard",
    "title": "Connectors in Context",
    "description": "Learn to use each connector correctly.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "I like tea, ___ not coffee. (simple contrast)",
          "back": "I like tea, but not coffee.",
          "example": "but = pero (neutral)."
        },
        {
          "id": "c2",
          "front": "I like tea. ___, I don't drink it often. (formal contrast)",
          "back": "I like tea. However, I don't drink it often.",
          "example": "however = however (formal)."
        },
        {
          "id": "c3",
          "front": "___ it was raining, we went out. (contrast with clause)",
          "back": "Although it rained, we went out.",
          "example": "although/though = aunque."
        },
        {
          "id": "c4",
          "front": "___ the rain, we went out. (contrast + noun)",
          "back": "Despite the rain, we went out.",
          "example": "despite/in spite of + noun/-ing."
        },
        {
          "id": "c5",
          "front": "I stayed at home ___ it was raining. (cause)",
          "back": "I stayed home because it was raining.",
          "example": "because + clause."
        },
        {
          "id": "c6",
          "front": "The delay was ___ bad weather. (formal cause)",
          "back": "The delay was due to bad weather.",
          "example": "due to + noun."
        },
        {
          "id": "c7",
          "front": "It was raining, ___ I stayed at home. (result)",
          "back": "It was raining, so I stayed home.",
          "example": "so = so (neutral)."
        },
        {
          "id": "c8",
          "front": "He studied a lot. ___, approved. (formal result)",
          "back": "She studied hard. Therefore, she passed.",
          "example": "therefore = therefore (formal)."
        },
        {
          "id": "c9",
          "front": "I saved money ___ to travel. (purpose)",
          "back": "I saved money so that I could travel.",
          "example": "so that = para que."
        },
        {
          "id": "c10",
          "front": "___, Does the hotel have a swimming pool. (formal addition)",
          "back": "In addition, the hotel has a pool.",
          "example": "in addition = in addition (formal)."
        }
      ]
    }
  },
