            "who",
            "which",
            "whose",
            "where"
          ],
          "correct": 2,
          "explanation": "whose = possession."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "Which can replace \"who\" with people in defining clauses?",
          "options": [
            "which",
            "where",
            "whose",
            "that"
          ],
          "correct": 3,
          "explanation": "that can replace who/which in defining clauses."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "\"The car ___ I bought is red.\" (cosa)",
          "correct": "which",
          "explanation": "which = for things (or that)."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "Non-defining clause: \"My sister, ___ is 25, is a teacher.\"",
          "options": [
            "that",
            "who",
            "which",
            "where"
          ],
          "correct": 1,
          "explanation": "Non-defining: use who, NOT that."
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "Can you omit in: \"The book (that) I bought\"?",
          "options": [
            "Yes — relative is the object.",
            "No — relative is the subject."
          ],
          "correct": 0,
          "explanation": "\"I\" is the subject, \"book\" is object → can omit."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "Can you omit in: \"The man who lives next door\"?",
          "options": [
            "Yes",
            "No — relative is the subject."
          ],
          "correct": 1,
          "explanation": "\"who\" is the subject → cannot omit."
        }
      ]
    }
