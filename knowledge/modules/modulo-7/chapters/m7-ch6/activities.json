  {
    "id": "m7-ch6-flash",
    "type": "flashcard",
    "title": "Comprehensive Quick Review",
    "description": "Review cards with questions from all modules.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "What is the difference between Present Simple and Present Continuous?",
          "back": "Simple = habits/facts (I work). Continuous = now/temporary (I am working).",
          "example": "I work every day. / I am working right now."
        },
        {
          "id": "c2",
          "front": "How is the Present Perfect formed?",
          "back": "have/has + past participle",
          "example": "I have visited Paris. She has finished."
        },
        {
          "id": "c3",
          "front": "When to use Past Simple vs Present Perfect?",
          "back": "Past Simple = время definido (yesterday). Present Perfect = experiencia/resultado.",
          "example": "I went yesterday. / I have been there (alguna vez)."
        },
        {
          "id": "c4",
          "front": "How is the First Conditional formed?",
          "back": "If + present simple, will + base verb",
          "example": "If it rains, I will stay home."
        },
        {
          "id": "c5",
          "front": "How is the Second Conditional formed?",
          "back": "If + past simple, would + base verb",
          "example": "If I had money, I would travel."
        },
        {
          "id": "c6",
          "front": "How is the Passive Voice formed?",
          "back": "be + past participle (+ by agent)",
          "example": "The book was written by Tolkien."
        },
        {
          "id": "c7",
          "front": "What are defining vs non-defining relative clauses?",
          "back": "Defining = essential (no commas). Non-defining = extra info (with commas).",
          "example": "The man who called is my boss. / My boss, who is 40, called."
        },
        {
          "id": "c8",
          "front": "What does \"under the weather\" mean?",
          "back": "Sentirse enfermo/mal",
          "example": "I'm feeling under the weather today."
        },
        {
          "id": "c9",
          "front": "❌ She have a car. → ✅ ?",
          "back": "✅ She HAS a car.",
          "example": "3rd person singular → has/does/is"
        },
        {
          "id": "c10",
          "front": "What is the difference between \"make\" and \"do\"?",
          "back": "Make = crear/producir. Do = realizar/actividad.",
          "example": "make a decision / do homework"
        },
        {
          "id": "c11",
          "front": "How is Direct → Reported Speech transformed?",
          "back": "Change tense back (backshift), change pronouns/time words.",
          "example": "\"I am happy\" → He said he was happy."
        },
        {
          "id": "c12",
          "front": "What is the difference between \"interesting\" and \"interested\"?",
          "back": "-ing = what causes. -ed = how you feel.",
          "example": "The movie is interesting. I am interested."
        }
      ]
    }
  },
