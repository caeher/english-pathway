    "title": "Modals in Context",
    "description": "Practice manners in different situations.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "You must wear a belt. (obligation)",
          "back": "You MUST wear a seatbelt.",
          "example": "Must = obligation (strong)."
        },
        {
          "id": "c2",
          "front": "You must not smoke here. (prohibition)",
          "back": "You MUSTN'T smoke here.",
          "example": "mustn't = prohibition."
        },
        {
          "id": "c3",
          "front": "You should study more. (advice)",
          "back": "You SHOULD study more.",
          "example": "Should = advice."
        },
        {
          "id": "c4",
          "front": "You shouldn't eat so much sugar.",
          "back": "You SHOULDN'T eat so much sugar.",
          "example": "shouldn't = not recommended."
        },
        {
          "id": "c5",
          "front": "It may rain. (~50%)",
          "back": "It MAY rain.",
          "example": "May = possibility (~50%)."
        },
        {
          "id": "c6",
          "front": "Can I come in? (formal)",
          "back": "MAY I come in?",
          "example": "May I...? = formal permission."
        },
        {
          "id": "c7",
          "front": "It could rain. (~30%)",
          "back": "It MIGHT rain.",
          "example": "Might = lower possibility."
        },
        {
          "id": "c8",
          "front": "Maybe they won't come.",
          "back": "They MIGHT NOT come.",
          "example": "might not = perhaps not."
        },
        {
          "id": "c9",
          "front": "She must be tired. (deduction)",
          "back": "She MUST be tired.",
          "example": "Must = logical deduction."
        },
        {
          "id": "c10",
          "front": "Should I call the doctor?",
          "back": "SHOULD I call the doctor?",
          "example": "Should I...? = seeking advice."
        },
        {
          "id": "c11",
          "front": "Maybe he's at home. (~30%)",
          "back": "He MIGHT be at home.",
          "example": "Might = uncertain possibility."
        },
        {
          "id": "c12",
          "front": "He may not come today. (~50%)",
          "back": "She MAY NOT come today.",
          "example": "May not = maybe not."
        }
      ]
    }
