          "example": "Must = logical deduction."
        },
        {
          "id": "c10",
          "front": "¿Debería llamar al doctor?",
          "back": "SHOULD I call the doctor?",
          "example": "Should I...? = seeking advice."
        },
        {
          "id": "c11",
          "front": "Quizás esté en casa. (~30%)",
          "back": "He MIGHT be at home.",
          "example": "Might = uncertain possibility."
