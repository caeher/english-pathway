[
  {
    "id": "m4-ch6-flash",
    "type": "flashcard",
    "title": "In, On, At — Practice",
    "description": "Learn when to use each preposition.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "___ the box (dentro)",
          "back": "IN the box",
          "example": "The keys are in the box."
        },
        {
          "id": "c2",
          "front": "___ the table (about)",
          "back": "ON the table",
          "example": "The book is on the table."
        },
        {
          "id": "c3",
          "front": "___ the bus stop (punto)",
          "back": "AT the bus stop",
          "example": "I'm waiting at the bus stop."
        },
        {
          "id": "c4",
          "front": "___ March (mes)",
          "back": "IN March",
          "example": "My birthday is in March."
        },
        {
          "id": "c5",
          "front": "___ Monday (day)",
          "back": "ON Monday",
          "example": "The meeting is on Monday."
        },
        {
          "id": "c6",
          "front": "___ 5 PM (hora)",
          "back": "AT 5 PM",
          "example": "I finish work at 5 PM."
        },
        {
          "id": "c7",
          "front": "___ the morning (part of the day)",
          "back": "IN the morning",
          "example": "I exercise in the morning."
        },
        {
          "id": "c8",
          "front": "___ night (exception)",
          "back": "AT night",
          "example": "AT night (not \"in the night\")."
        },
        {
          "id": "c9",
          "front": "next to (place)",
          "back": "NEXT TO",
          "example": "The bank is next to the school."
        },
        {
          "id": "c10",
          "front": "entre (lugar)",
          "back": "BETWEEN",
          "example": "The park is between the bank and the church."
        },
        {
          "id": "c11",
          "front": "below (place)",
          "back": "UNDER",
          "example": "The cat is under the table."
        },
        {
          "id": "c12",
          "front": "in front of (place)",
          "back": "IN FRONT OF",
          "example": "The tree is in front of the house."
        }
      ]
    }
  },
