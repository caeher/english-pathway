[
  {
    "id": "m4-ch1-flash",
    "type": "flashcard",
    "title": "Adjetivo → Adverbio",
    "description": "Transform adjectives into adverbs.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "slow → ?",
          "back": "slowly",
          "example": "He drives slowly."
        },
        {
          "id": "c2",
          "front": "quick → ?",
          "back": "quickly",
          "example": "She runs quickly."
        },
        {
          "id": "c3",
          "front": "happy → ?",
          "back": "happily",
          "example": "y → ily: They danced happily."
        },
        {
          "id": "c4",
          "front": "easy → ?",
          "back": "easily",
          "example": "y → ily: She won easily."
        },
        {
          "id": "c5",
          "front": "careful → ?",
          "back": "carefully",
          "example": "He drives carefully."
        },
        {
          "id": "c6",
          "front": "terrible → ?",
          "back": "terribly",
          "example": "le → ly: She played terribly."
        },
        {
          "id": "c7",
          "front": "good → ?",
          "back": "well",
          "example": "IRREGULAR: She sings well."
        },
        {
          "id": "c8",
          "front": "fast → ?",
          "back": "fast (same!)",
          "example": "He runs fast. (NOT fastly)"
        },
        {
          "id": "c9",
          "front": "hard → ?",
          "back": "hard (same!)",
          "example": "She works hard. (NOT hardly — that means \"barely\")"
        },
        {
          "id": "c10",
          "front": "beautiful → ?",
          "back": "beautifully",
          "example": "She dances beautifully."
        },
        {
          "id": "c11",
          "front": "loud → ?",
          "back": "loudly",
          "example": "He speaks loudly."
        },
        {
          "id": "c12",
          "front": "late → ?",
          "back": "late (same!)",
          "example": "He arrived late. (NOT lately — that means \"recently\")"
        }
      ]
    }
  },
