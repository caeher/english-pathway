  {
    "id": "m4-ch1-quiz",
    "type": "quiz",
    "title": "Quiz: Adjetivos y Adverbios",
    "description": "Show that you know when to use adjectives and adverbs.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "\"She sings ___.\"",
          "options": [
            "beautiful",
            "beautifully",
            "beauty",
            "beautifuly"
          ],
          "correct": 1,
          "explanation": "Describes verb → adverb: beautifully."
        },
        {
          "id": "q2",
          "type": "multiple-choice",
          "question": "\"He is a ___ driver.\"",
          "options": [
            "carefully",
            "careful",
            "care",
            "caring"
          ],
          "correct": 1,
          "explanation": "Before noun → adjective: careful."
        },
        {
          "id": "q3",
          "type": "fill-blank",
          "question": "\"She speaks English ___.\" (good)",
          "correct": "well",
          "explanation": "good → well (adverb, irregular)."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "\"He runs very ___.\"",
          "options": [
            "fastly",
            "fast",
            "faster",
            "fasting"
          ],
          "correct": 1,
          "explanation": "Fast stays the same as adverb (no \"fastly\")."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "\"She dances ___.\" (beautiful)",
          "correct": "beautifully",
          "explanation": "beautiful → beautifully (+ ly)."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "\"They work very ___.\"",
          "options": [
            "hardly",
            "hard",
            "harder",
            "harding"
          ],
          "correct": 1,
          "explanation": "Hard = adverb too (hardly = \"barely\"!)."
        },
        {
          "id": "q7",
          "type": "fill-blank",
          "question": "\"He arrived ___.\" (late)",
          "correct": "late",
          "explanation": "Late stays the same (lately = \"recently\")."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "Which is WRONG?",
          "options": [
            "She sings well.",
            "She sings good.",
            "She is a good singer.",
            "She sings beautifully."
          ],
          "correct": 1,
          "explanation": "\"She sings good\" is wrong → She sings WELL."
        },
        {
          "id": "q9",
          "type": "fill-blank",
          "question": "\"The children played ___.\" (happy)",
          "correct": "happily",
          "explanation": "happy → happily (y → ily)."
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "\"She is ___ at her job.\" (good/well)",
          "options": [
            "well",
            "good",
            "goodly",
            "welling"
          ],
          "correct": 1,
          "explanation": "After \"is\" → adjective: She is GOOD at her job."
        }
      ]
    }
  },
