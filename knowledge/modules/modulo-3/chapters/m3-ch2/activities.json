  {
    "id": "m3-ch2-flash",
    "type": "flashcard",
    "title": "Simple or Continuous?",
    "description": "Decide which verb tense to use in each situation.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "I ___ coffee every morning. (drink)",
          "back": "I DRINK coffee every morning.",
          "example": "Routine → Present Simple."
        },
        {
          "id": "c2",
          "front": "I ___ tea right now. (drink)",
          "back": "I'M DRINKING tea right now.",
          "example": "Happening now → Present Continuous."
        },
        {
          "id": "c3",
          "front": "She ___ French and German. (speak)",
          "back": "She SPEAKS French and German.",
          "example": "Ability/fact → Present Simple."
        },
        {
          "id": "c4",
          "front": "She ___ on the phone now. (speak)",
          "back": "She'S SPEAKING on the phone now.",
          "example": "Action in progress → Present Continuous."
        },
        {
          "id": "c5",
          "front": "I ___ this movie. (love)",
          "back": "I LOVE this movie.",
          "example": "Stative verb → ALWAYS Simple (not: I'm loving)."
        },
        {
          "id": "c6",
          "front": "He ___ a car. (have = poseer)",
          "back": "He HAS a car.",
          "example": "Stative (possession) → Simple."
        },
        {
          "id": "c7",
          "front": "He ___ lunch now. (have = comer)",
          "back": "He'S HAVING lunch now.",
          "example": "\"Have\" as activity → Continuous is OK!"
        },
        {
          "id": "c8",
          "front": "Water ___ at 100°C. (boil)",
          "back": "Water BOILS at 100°C.",
          "example": "Scientific fact → Present Simple."
        },
        {
          "id": "c9",
          "front": "The water ___. Turn it off! (boil)",
          "back": "The water IS BOILING.",
          "example": "Happening right now → Present Continuous."
        },
        {
          "id": "c10",
          "front": "They ___ tennis on Sundays. (play)",
          "back": "They PLAY tennis on Sundays.",
          "example": "Every Sunday = habit → Simple."
        },
        {
          "id": "c11",
          "front": "They ___ tennis now. (play)",
          "back": "They'RE PLAYING tennis now.",
          "example": "Now = in progress → Continuous."
        },
        {
          "id": "c12",
          "front": "I ___ the answer. (know)",
          "back": "I KNOW the answer.",
          "example": "Stative verb → ALWAYS Simple."
        }
      ]
    }
  },
