[
  {
    "id": "m3-ch6-svg",
    "type": "svg-scene",
    "title": "Deseos, Gustos y Necesidades",
    "description": "Explore the different ways to express what you want, like and need.",
    "props": {
      "scene": {
        "viewBox": "0 0 700 400",
        "bg": "#fdf2f8",
        "items": [
          {
            "id": "title",
            "type": "rect",
            "x": 100,
            "y": 5,
            "width": 500,
            "height": 45,
            "fill": "#ec4899",
            "label": "❤️ Desires, Likes & Needs",
            "labelEn": "Express what you want, like and need!"
          },
          {
            "id": "want",
            "type": "rect",
            "x": 30,
            "y": 60,
            "width": 200,
            "height": 80,
            "fill": "#fce7f3",
            "label": "🌟 Want to",
            "labelEn": "I WANT TO travel. She WANTS TO learn. He DOESN'T WANT TO go."
          },
          {
            "id": "like",
            "type": "rect",
            "x": 250,
            "y": 60,
            "width": 200,
            "height": 80,
            "fill": "#bbf7d0",
            "label": "😊 Like + ing",
            "labelEn": "I LIKE READING. She LIKES COOKING. They DON'T LIKE RUNNING."
          },
          {
            "id": "need",
            "type": "rect",
            "x": 470,
            "y": 60,
            "width": 200,
            "height": 80,
            "fill": "#bfdbfe",
            "label": "📋 Need to",
            "labelEn": "I NEED TO study. He NEEDS TO work. She DOESN'T NEED TO hurry."
          },
          {
            "id": "would",
            "type": "rect",
            "x": 140,
            "y": 160,
            "width": 420,
            "height": 70,
            "fill": "#fde68a",
            "label": "🎩 Would like (I'd like)",
            "labelEn": "I'D LIKE a coffee = I WOULD LIKE a coffee. More polite than 'I want'!"
          },
          {
            "id": "ex1",
            "type": "rect",
            "x": 30,
            "y": 250,
            "width": 310,
            "height": 55,
            "fill": "#dcfce7",
            "label": "✅ Do you want to play?",
            "labelEn": "Question: Do/Does + subject + want to + verb."
          },
          {
            "id": "ex2",
            "type": "rect",
            "x": 360,
            "y": 250,
            "width": 310,
            "height": 55,
            "fill": "#dbeafe",
            "label": "✅ Would you like some tea?",
            "labelEn": "Would you like…? = Would you like...? (polite offer)"
          },
          {
            "id": "note",
            "type": "rect",
            "x": 50,
            "y": 330,
            "width": 600,
            "height": 50,
            "fill": "#fef9c3",
            "label": "💡 Like + ing vs. Like + to",
            "labelEn": "I like swimming = I like to swim. Both are correct! -ing is more common in British English."
          }
        ]
      }
    }
  },
  {
    "id": "m3-ch6-flash",
    "type": "flashcard",
    "title": "Want, Like, Need y Would Like",
    "description": "Practice expressing desires, tastes and needs.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "Quiero viajar. (want)",
          "back": "I WANT TO travel.",
          "example": "want to + base verb."
        },
        {
          "id": "c2",
          "front": "She wants to learn English.",
          "back": "She WANTS TO learn English.",
          "example": "He/She/It → wants to."
        },
        {
          "id": "c3",
          "front": "No quiero ir. (negativo)",
          "back": "I DON'T WANT TO go.",
          "example": "don't want to + base verb."
        },
        {
          "id": "c4",
          "front": "Do you want to play? (ask)",
          "back": "DO you WANT TO play?",
          "example": "Do + subject + want to + verb."
        },
        {
          "id": "c5",
          "front": "Me gusta leer. (like + ing)",
          "back": "I LIKE READING.",
          "example": "like + verb-ing."
        },
        {
          "id": "c6",
          "front": "A ella le gusta cocinar.",
          "back": "She LIKES COOKING.",
          "example": "He/She/It → likes + -ing."
        },
        {
          "id": "c7",
          "front": "No me gusta correr.",
          "back": "I DON'T LIKE RUNNING.",
          "example": "don't like + -ing."
        },
        {
          "id": "c8",
          "front": "Necesito estudiar. (need)",
          "back": "I NEED TO study.",
          "example": "need to + base verb."
        },
        {
          "id": "c9",
          "front": "Ella necesita trabajar.",
          "back": "She NEEDS TO work.",
          "example": "He/She/It → needs to."
        },
        {
          "id": "c10",
          "front": "No necesitas apurarte.",
          "back": "You DON'T NEED TO hurry.",
          "example": "don't need to + verb."
        },
        {
          "id": "c11",
          "front": "I would like a coffee. (courteous)",
          "back": "I'D LIKE a coffee.",
          "example": "I'd like = I would like (more polite than want)."
        },
        {
          "id": "c12",
          "front": "Would you like some tea?",
          "back": "WOULD you LIKE some tea?",
          "example": "Would you like...? = polite offer."
        }
      ]
    }
  },
