[
  {
    "id": "m3-ch5-flash",
    "type": "flashcard",
    "title": "Can and Could in Action",
    "description": "Practice all the uses of can and could.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "I / swim (habilidad presente)",
          "back": "I CAN swim.",
          "example": "Can + base verb (no \"to\")."
        },
        {
          "id": "c2",
          "front": "She / speak French (habilidad)",
          "back": "She CAN speak French.",
          "example": "Can for present skills."
        },
        {
          "id": "c3",
          "front": "I / not / drive (negativo)",
          "back": "I CAN'T drive.",
          "example": "can't = cannot."
        },
        {
          "id": "c4",
          "front": "___ I use your phone? (permiso)",
          "back": "CAN I use your phone?",
          "example": "Can to ask permission."
        },
        {
          "id": "c5",
          "front": "I / swim / when I was 5 (pasado)",
          "back": "I COULD swim when I was 5.",
          "example": "Could = ability in the past."
        },
        {
          "id": "c6",
          "front": "She / not / read / at age 3 (pasado)",
          "back": "She COULDN'T read at age 3.",
          "example": "couldn't = could not."
        },
        {
          "id": "c7",
          "front": "___ you help me, please? (courtesy)",
          "back": "COULD you help me, please?",
          "example": "Could for polite requests."
        },
        {
          "id": "c8",
          "front": "It ___ rain later (posibilidad)",
          "back": "It COULD rain later.",
          "example": "Could = posibilidad incierta."
        },
        {
          "id": "c9",
          "front": "___ you swim? (present question)",
          "back": "CAN you swim?",
          "example": "Can + subject + base verb?"
        },
        {
          "id": "c10",
          "front": "Yes, I ___. / No, I ___.",
          "back": "Yes, I CAN. / No, I CAN'T.",
          "example": "Short answers with can."
        },
        {
          "id": "c11",
          "front": "___ he ride a bike when he was 4?",
          "back": "COULD he ride a bike?",
          "example": "Could for questions about the past."
        },
        {
          "id": "c12",
          "front": "We ___ go tomorrow. (posibilidad)",
          "back": "We CAN go tomorrow.",
          "example": "Can = posibilidad."
        }
      ]
    }
  },
