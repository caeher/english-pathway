          "right": "going to"
        },
        {
          "left": "Promise",
          "right": "will"
        },
        {
          "left": "Intention",
          "right": "going to"
        },
        {
          "left": "Offer to help",
          "right": "will"
        },
        {
          "left": "Future plans",
          "right": "going to"
        }
      ]
    }
  },
