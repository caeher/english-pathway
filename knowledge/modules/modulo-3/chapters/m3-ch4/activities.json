[
  {
    "id": "m3-ch4-flash",
    "type": "flashcard",
    "title": "Will vs. Going To",
    "description": "Practice choosing the correct future form.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "\"The phone is ringing.\" → I ___ answer it.",
          "back": "I'LL answer it.",
          "example": "Spontaneous decision → will."
        },
        {
          "id": "c2",
          "front": "\"What are your plans?\" → I ___ visit Paris.",
          "back": "I'M GOING TO visit Paris.",
          "example": "Already planned → going to."
        },
        {
          "id": "c3",
          "front": "\"I think it ___ (rain) tomorrow.\"",
          "back": "I think it WILL rain.",
          "example": "Prediction (opinion) → will."
        },
        {
          "id": "c4",
          "front": "\"Look at those clouds!\" → It ___ rain!",
          "back": "It'S GOING TO rain!",
          "example": "Prediction (evidence) → going to."
        },
        {
          "id": "c5",
          "front": "\"Don't worry.\" → I ___ help you.",
          "back": "I'LL help you.",
          "example": "Offer/promise → will."
        },
        {
          "id": "c6",
          "front": "\"Tomorrow\" → She ___ start a new job.",
          "back": "She'S GOING TO start a new job.",
          "example": "Plan already decided → going to."
        },
        {
          "id": "c7",
          "front": "\"I'm sure\" → He ___ pass the exam.",
          "back": "He'LL pass the exam.",
          "example": "Belief/opinion → will."
        },
        {
          "id": "c8",
          "front": "\"She ___ (not/come) to the party.\"",
          "back": "She WON'T come to the party.",
          "example": "Negative with will → won't + base verb."
        },
        {
          "id": "c9",
          "front": "\"They ___ (not/travel) this summer.\"",
          "back": "They AREN'T GOING TO travel.",
          "example": "Negative with going to."
        },
        {
          "id": "c10",
          "front": "\"___ you ___ (be) at the meeting?\"",
          "back": "Will you BE at the meeting?",
          "example": "Question with will."
        },
        {
          "id": "c11",
          "front": "\"___ he ___ (study) tonight?\"",
          "back": "Is he GOING TO study tonight?",
          "example": "Question with going to."
        },
        {
          "id": "c12",
          "front": "\"___ I open the window?\" (sugerencia)",
          "back": "SHALL I open the window?",
          "example": "Shall I...? = Do you want me to...? (suggestion)."
        }
      ]
    }
  },
  {
    "id": "m3-ch4-match",
    "type": "word-match",
    "title": "Will o Going To",
    "description": "Match each situation with the correct form of the future.",
    "props": {
      "pairs": [
        {
          "left": "Spontaneous decision",
          "right": "will"
        },
        {
          "left": "Already planned",
          "right": "going to"
        },
        {
          "left": "Prediction (opinion)",
          "right": "will"
        },
        {
          "left": "Prediction (evidence)",
          "right": "going to"
        },
        {
          "left": "Promise",
          "right": "will"
        },
        {
          "left": "Intention",
          "right": "going to"
        },
        {
          "left": "Offer to help",
          "right": "will"
        },
        {
          "left": "Future plans",
          "right": "going to"
        }
      ]
    }
  },
  {
    "id": "m3-ch4-sentence",
    "type": "sentence-builder",
    "title": "Talk about the Future",
    "description": "Order the words to make sentences about the future.",
    "props": {
