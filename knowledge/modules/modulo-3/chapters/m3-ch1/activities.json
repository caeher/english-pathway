  {
    "id": "m3-ch1-quiz",
    "type": "quiz",
    "title": "Quiz: Presente Continuo",
    "description": "Show that you master the present continuous.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "\"She ___ (read) a book right now.\"",
          "options": [
            "reads",
            "is reading",
            "reading",
            "read"
          ],
          "correct": 1,
          "explanation": "Present continuous: is + reading."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "\"I ___ (work) from home today.\"",
          "correct": "am working",
          "explanation": "I am working = I'm working."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "What is the -ing form of \"make\"?",
          "options": [
            "makeing",
            "making",
            "makking",
            "mading"
          ],
          "correct": 1,
          "explanation": "Drop the -e: make → making."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "What is the -ing form of \"run\"?",
          "options": [
            "runing",
            "running",
            "runeing",
            "ranning"
          ],
          "correct": 1,
          "explanation": "Double the consonant: run → running."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "\"They ___ (play) football in the garden.\"",
          "correct": "are playing",
          "explanation": "They are playing."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "\"___ you ___ (study) for the exam?\"",
          "options": [
            "Do / study",
            "Are / studying",
            "Is / studying",
            "Does / study"
          ],
          "correct": 1,
          "explanation": "Are you studying? = present continuous question."
        },
        {
          "id": "q7",
          "type": "fill-blank",
          "question": "\"He ___ (not/eat) lunch right now.\"",
          "correct": "is not eating",
          "explanation": "He is not eating / He isn't eating."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "What is the -ing form of \"sit\"?",
          "options": [
            "siting",
            "sitting",
            "sitiing",
            "settin"
          ],
          "correct": 1,
          "explanation": "Double the consonant: sit → sitting."
        },
        {
          "id": "q9",
          "type": "fill-blank",
          "question": "\"We ___ (meet) at 5 tomorrow.\" (futuro)",
          "correct": "are meeting",
          "explanation": "Present continuous for future plans: We are meeting."
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "What is the -ing form of \"die\"?",
          "options": [
            "dieing",
            "dying",
            "diying",
            "deing"
          ],
          "correct": 1,
          "explanation": "ie → y + ing: die → dying."
        }
      ]
    }
  },
