[
  {
    "id": "m3-ch1-flash",
    "type": "flashcard",
    "title": "Conjugations in Present Continuous",
    "description": "Practice forming the present continuous.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "I / work (present continuous)",
          "back": "I am working / I'm working",
          "example": "I'm working from home today."
        },
        {
          "id": "c2",
          "front": "She / read (present continuous)",
          "back": "She is reading / She's reading",
          "example": "She's reading a novel."
        },
        {
          "id": "c3",
          "front": "They / play (present continuous)",
          "back": "They are playing / They're playing",
          "example": "They're playing basketball."
        },
        {
          "id": "c4",
          "front": "He / make (-e rule)",
          "back": "He is making / He's making",
          "example": "Drop -e + ing: make → making."
        },
        {
          "id": "c5",
          "front": "She / run (doubling rule)",
          "back": "She is running / She's running",
          "example": "Double consonant + ing: run → running."
        },
        {
          "id": "c6",
          "front": "I / sit (doubling rule)",
          "back": "I am sitting / I'm sitting",
          "example": "Double consonant + ing: sit → sitting."
        },
        {
          "id": "c7",
          "front": "My phone / die (-ie rule)",
          "back": "dying / die → dying",
          "example": "ie → y + ing: die → dying."
        },
        {
          "id": "c8",
          "front": "I / not / work (negativo)",
          "back": "I'm not working",
          "example": "I'm not working today."
        },
        {
          "id": "c9",
          "front": "She / not / eat (negativo)",
          "back": "She isn't eating / She's not eating",
          "example": "She isn't eating lunch."
        },
        {
          "id": "c10",
          "front": "___you / study? (ask)",
          "back": "Are you studying?",
          "example": "Are you studying for the exam?"
        },
        {
          "id": "c11",
          "front": "We / meet / tomorrow (futuro)",
          "back": "We are meeting tomorrow",
          "example": "We're meeting at 5 tomorrow."
        },
        {
          "id": "c12",
          "front": "Prices / rise (tendencia)",
          "back": "Prices are rising",
          "example": "Prices are rising this year."
        }
      ]
    }
  },
