[
  {
    "id": "m3-ch3-flash",
    "type": "flashcard",
    "title": "Past Continuous: Practice",
    "description": "Practice the formation and uses of the past continuous.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "I / watch TV / at 9 PM",
          "back": "I was watching TV at 9 PM.",
          "example": "I/He/She/It → was + -ing."
        },
        {
          "id": "c2",
          "front": "They / study / all night",
          "back": "They were studying all night.",
          "example": "You/We/They → were + -ing."
        },
        {
          "id": "c3",
          "front": "She / cook / when he arrived",
          "back": "She was cooking when he arrived.",
          "example": "Continuous action interrupted by simple past."
        },
        {
          "id": "c4",
          "front": "While I / walk / it started to rain",
          "back": "While I was walking, it started to rain.",
          "example": "while + continuous, simple interrupts."
        },
        {
          "id": "c5",
          "front": "They / play / while she / read",
          "back": "They were playing while she was reading.",
          "example": "Two simultaneous continuous actions."
        },
        {
          "id": "c6",
          "front": "He / not / work / yesterday afternoon",
          "back": "He wasn't working yesterday afternoon.",
          "example": "Negative: wasn't + -ing."
        },
        {
          "id": "c7",
          "front": "___ you / sleep / at midnight?",
          "back": "Were you sleeping at midnight?",
          "example": "Question: Were + subject + -ing?"
        },
        {
          "id": "c8",
          "front": "The baby / sleep / when I got home",
          "back": "The baby was sleeping when I got home.",
          "example": "Background action + when + past simple."
        },
        {
          "id": "c9",
          "front": "We / drive / to the airport / at 6 AM",
          "back": "We were driving to the airport at 6 AM.",
          "example": "We → were driving."
        },
        {
          "id": "c10",
          "front": "What / you / do / at 10 PM?",
          "back": "What were you doing at 10 PM?",
          "example": "Wh-question in past continuous."
        }
      ]
    }
  },
  {
    "id": "m3-ch3-match",
    "type": "word-match",
    "title": "When vs. While",
    "description": "Match each sentence with the correct conjunction.",
    "props": {
      "pairs": [
        {
          "left": "___ I was eating…",
          "right": "While"
        },
        {
          "left": "___ the phone rang…",
          "right": "When"
        },
        {
          "left": "___ she was sleeping…",
          "right": "While"
        },
        {
          "left": "___ he arrived…",
          "right": "When"
        },
        {
          "left": "___ they were dancing…",
          "right": "While"
        },
        {
          "left": "___ it started to rain…",
          "right": "When"
        },
        {
          "left": "___ we were studying…",
          "right": "While"
        },
        {
          "left": "___ the lights went out…",
          "right": "When"
        }
      ]
    }
  },
  {
    "id": "m3-ch3-sentence",
    "type": "sentence-builder",
    "title": "Tell what was happening",
    "description": "Arrange the words to form sentences in the past continuous.",
    "props": {
      "sentences": [
        {
          "prompt": "I was watching TV at 9:",
