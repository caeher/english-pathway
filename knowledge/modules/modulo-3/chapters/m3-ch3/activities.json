            "I",
            "was",
            "watching",
            "TV",
            "at",
            "9"
          ],
          "correct": "I was watching TV at 9"
        },
        {
          "prompt": "She was cooking when he arrived:",
          "words": [
            "She",
            "was",
            "cooking",
            "when",
            "he",
            "arrived"
          ],
          "correct": "She was cooking when he arrived"
        },
        {
          "prompt": "While it was raining, we read:",
          "words": [
            "While",
            "it",
            "was",
            "raining",
            "we",
            "were",
            "reading"
          ],
          "correct": "While it was raining we were reading"
        },
        {
          "prompt": "No estaban estudiando:",
          "words": [
            "They",
            "weren't",
            "studying"
          ],
          "correct": "They weren't studying"
        },
        {
          "prompt": "Were you sleeping at midnight?:",
          "words": [
            "Were",
            "you",
            "sleeping",
            "at",
            "midnight?"
          ],
          "correct": "Were you sleeping at midnight?"
        },
        {
          "prompt": "The baby was sleeping when I arrived:",
          "words": [
            "The",
            "baby",
            "was",
            "sleeping",
            "when",
            "I",
            "arrived"
          ],
          "correct": "The baby was sleeping when I arrived"
        },
        {
          "prompt": "What were you doing?:",
          "words": [
            "What",
            "were",
            "you",
            "doing?"
          ],
          "correct": "What were you doing?"
        },
        {
          "prompt": "He was running in the park:",
          "words": [
            "He",
            "was",
            "running",
            "in",
            "the",
            "park"
          ],
          "correct": "He was running in the park"
        }
      ]
    }
  },
  {
    "id": "m3-ch3-quiz",
    "type": "quiz",
    "title": "Quiz: Pasado Continuo",
    "description": "Show that you master the past continuous.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "\"I ___ (watch) TV at 9 PM last night.\"",
          "options": [
            "watched",
            "was watching",
            "were watching",
            "watching"
          ],
          "correct": 1,
          "explanation": "I → was watching."
        },
        {
          "id": "q2",
          "type": "fill-blank",
          "question": "\"They ___ (study) when the lights went out.\"",
          "correct": "were studying",
          "explanation": "They → were studying."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "\"She was cooking ___ he arrived.\"",
          "options": [
            "while",
            "when",
            "during",
            "before"
          ],
          "correct": 1,
          "explanation": "\"when\" + short action (past simple)."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "\"___ she was sleeping, the phone rang.\"",
          "options": [
            "When",
            "While",
            "During",
            "After"
          ],
          "correct": 1,
          "explanation": "\"while\" + continuous action."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "\"He ___ (not/work) yesterday afternoon.\"",
          "correct": "wasn't working",
          "explanation": "He wasn't working."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "\"___ you ___ at midnight?\"",
          "options": [
            "Did / sleeping",
            "Were / sleeping",
            "Was / sleeping",
            "Are / sleeping"
          ],
          "correct": 1,
          "explanation": "Were you sleeping? (you → were)."
        },
        {
          "id": "q7",
          "type": "fill-blank",
          "question": "\"While I ___ (walk) home, it started to rain.\"",
          "correct": "was walking",
          "explanation": "While I was walking (continuous background)."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "Which uses past continuous correctly?",
          "options": [
            "I was work yesterday.",
            "She were cooking at 8.",
            "They was playing.",
            "He was reading a book."
          ],
          "correct": 3,
          "explanation": "He → was reading (correct)."
        },
        {
          "id": "q9",
          "type": "fill-blank",
          "question": "\"What ___ you ___ at 10 PM?\" (do)",
          "correct": "were doing",
          "explanation": "What were you doing? (Wh + were + -ing)."
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "\"___ they playing while she was reading?\"",
          "options": [
            "Was",
            "Were",
            "Did",
            "Are"
          ],
          "correct": 1,
          "explanation": "They → Were they playing?"
        }
      ]
    }
  },
