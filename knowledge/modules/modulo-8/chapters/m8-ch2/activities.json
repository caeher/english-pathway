  {
    "id": "m8-ch2-quiz",
    "type": "quiz",
    "title": "Quiz Gramatical",
    "description": "Choose the correct form of the verb. Be careful with the third person!",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "He ___ to school every day.",
          "options": [
            "go",
            "goes",
            "going",
            "gone"
          ],
          "correct": 1,
          "explanation": "He/She/It + goes (tercera persona singular)."
        },
        {
          "id": "q2",
          "type": "multiple-choice",
          "question": "They ___ soccer on weekends.",
          "options": [
            "plays",
            "playing",
            "play",
            "played"
          ],
          "correct": 2,
          "explanation": "They + play (without -s for I/you/we/they)."
        },
        {
          "id": "q3",
          "type": "fill-blank",
          "question": "She ___ (study) English every day.",
          "correct": "studies",
          "explanation": "Study → studies with he/she/it (y → ies)."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "I ___ coffee in the morning.",
          "options": [
            "drinks",
            "drink",
            "drinking",
            "drank"
          ],
          "correct": 1,
          "explanation": "I + drink (forma base)."
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "___ she like chocolate?",
          "options": [
            "Do",
            "Does",
            "Is",
            "Has"
          ],
          "correct": 1,
          "explanation": "Does + he/she/it for questions in the simple present."
        },
        {
          "id": "q6",
          "type": "fill-blank",
          "question": "He ___ (not like) fish.",
          "correct": "doesn't like",
          "explanation": "Negativo: He doesn't like (does + not + verbo base)."
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "We ___ in a big city.",
          "options": [
            "lives",
            "live",
            "living",
            "lived"
          ],
          "correct": 1,
          "explanation": "We + live (forma base)."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "She ___ TV every night.",
          "options": [
            "watch",
            "watchs",
            "watches",
            "watching"
          ],
          "correct": 2,
          "explanation": "Watch → watches with he/she/it (-ch + es)."
        },
        {
          "id": "q9",
          "type": "multiple-choice",
          "question": "___ you speak Spanish?",
          "options": [
            "Does",
            "Do",
            "Are",
            "Is"
          ],
          "correct": 1,
          "explanation": "Do + I/you/we/they for questions."
        },
        {
          "id": "q10",
          "type": "fill-blank",
          "question": "The cat ___ (sleep) on the sofa.",
          "correct": "sleeps",
          "explanation": "The cat (= it) + sleeps."
        }
      ]
    }
  },
