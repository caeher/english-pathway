          "options": [
            "Give me coffee",
            "Coffee now",
            "I'd like a coffee, please",
            "I want coffee"
          ],
          "correct": 2,
          "explanation": "\"I'd like... please\" is the polite way to order."
        },
        {
          "id": "q7",
