  {
    "id": "m8-ch3-flash",
    "type": "flashcard",
    "title": "Phonics Flashcards",
    "description": "Learn each phonetic symbol with its example and articulatory description.",
    "props": {
      "cards": [
        {
          "id": "p1",
          "front": "/θ/ — \"th\" sorda",
          "back": "think, three, bath",
          "example": "Place your tongue between your teeth and blow air gently."
        },
        {
          "id": "p2",
          "front": "/ð/ — \"th\" sonora",
          "back": "this, that, mother",
          "example": "Like /θ/ but with vibration in the throat."
        },
        {
          "id": "p3",
          "front": "/æ/ — \"a\" abierta",
          "back": "cat, hat, apple",
          "example": "Open your mouth more than for \"e\" but less than for \"a\"."
        },
        {
          "id": "p4",
          "front": "/ʌ/ — \"u\" corta",
          "back": "cup, bus, love",
          "example": "A relaxed and short \"a\". The mouth barely opens."
        },
        {
          "id": "p5",
          "front": "/ɪ/ — \"i\" corta",
          "back": "ship, sit, fish",
          "example": "A relaxed \"i\", without tensing the lips."
        },
        {
          "id": "p6",
          "front": "/iː/ — \"i\" larga",
          "back": "sheep, see, eat",
          "example": "A long, tense \"i\", like smiling."
        },
        {
          "id": "p7",
          "front": "/ɹ/ — \"r\" inglesa",
          "back": "red, run, right",
          "example": "The tongue does NOT touch anything. It curves back."
        },
        {
          "id": "p8",
          "front": "/h/ — aspirada",
          "back": "house, happy, hello",
          "example": "Just a breath of air, like fogging up a mirror."
        }
      ]
    }
  },
