    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "The sound /θ/ is found in which word?",
          "options": [
            "sink",
            "think",
            "sing",
            "thing"
          ],
          "correct": 1,
          "explanation": "/θ/ is the \"th\" in \"think\". \"Sink\" uses /s/."
        },
        {
          "id": "q2",
          "type": "multiple-choice",
          "question": "\"Ship\" has the vowel sound:",
          "options": [
            "/iː/ (long)",
            "/ɪ/ (short)",
            "/æ/",
            "/ʌ/"
          ],
          "correct": 1,
          "explanation": "Ship = /ʃɪp/ with short /ɪ/. Sheep = /ʃiːp/ with long /iː/."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "The vowel in \"cat\" is:",
          "options": [
            "/ʌ/",
            "/æ/",
            "/ɑː/",
            "/e/"
          ],
          "correct": 1,
          "explanation": "Cat = /kæt/. The /æ/ sound is between \"a\" and \"e\"."
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "The vowel in \"cup\" is:",
          "options": [
            "/æ/",
            "/uː/",
            "/ʌ/",
            "/ɒ/"
          ],
          "correct": 2,
          "explanation": "Cup = /kʌp/. Short, relaxed \"uh\" sound."
        },
        {
          "id": "q5",
          "type": "fill-blank",
          "question": "The word \"this\" contains the sound /____/.",
          "correct": "ð",
          "explanation": "\"This\" uses /ð/, the voiced \"th\"."
        },
        {
          "id": "q6",
          "type": "multiple-choice",
          "question": "Which pair are minimal pairs?",
          "options": [
            "cat / dog",
            "ship / sheep",
            "book / cook",
            "pen / paper"
          ],
          "correct": 1,
          "explanation": "Ship /ʃɪp/ and sheep /ʃiːp/ differ only in one vowel sound."
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "In English, \"r\" is pronounced by:",
          "options": [
            "Tongue touches the palate",
            "Tongue curls back without touching",
            "Tongue vibrates",
            "Lips close"
          ],
          "correct": 1,
          "explanation": "English /ɹ/ — the tongue curls back but does NOT touch anything."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "Questions (yes/no) in English usually have:",
          "options": [
            "Falling intonation ↘️",
            "Rising intonation ↗️",
