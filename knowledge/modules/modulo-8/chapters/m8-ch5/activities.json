[
  {
    "id": "m8-ch5-quiz",
    "type": "quiz",
    "title": "Conversational Quiz — Choose the Best Answer",
    "description": "In each situation, choose the most natural and appropriate response.",
    "props": {
      "questions": [
        {
          "id": "q1",
          "type": "multiple-choice",
          "question": "Waiter: \"Good evening! Table for two?\" — You:",
          "options": [
            "Yes, two.",
            "Yes, please!",
            "Two people.",
            "Table."
          ],
          "correct": 1,
          "explanation": "\"Yes, please!\" is natural and polite."
        },
        {
          "id": "q2",
          "type": "multiple-choice",
          "question": "Shop assistant: \"Can I help you?\" — You:",
          "options": [
            "I'm just looking, thanks.",
            "No.",
            "Go away.",
            "I don't need you."
          ],
          "correct": 0,
          "explanation": "\"I'm just looking, thanks\" is the polite standard response."
        },
        {
          "id": "q3",
          "type": "multiple-choice",
          "question": "Someone says: \"Nice to meet you!\" — You respond:",
          "options": [
            "Thank you",
            "Nice to meet you too!",
            "I'm happy",
            "Yes, nice"
          ],
          "correct": 1,
          "explanation": "The standard response mirrors the greeting: \"Nice to meet you too!\""
        },
        {
          "id": "q4",
          "type": "multiple-choice",
          "question": "At a restaurant: \"Are you ready to order?\" — You:",
          "options": [
            "I'd like a hamburger, please.",
            "Hamburger.",
            "Give me food.",
            "I eat hamburger."
          ],
          "correct": 0,
          "explanation": "\"I'd like... please\" is the polite way to order."
        },
        {
          "id": "q5",
          "type": "multiple-choice",
          "question": "\"Where are you from?\" — You:",
          "options": [
            "I'm from Mexico.",
            "Mexico.",
            "I from Mexico.",
            "My country Mexico."
          ],
          "correct": 0,
          "explanation": "\"I'm from [country]\" is the correct structure."
        },
        {
          "id": "q6",
          "type": "fill-blank",
          "question": "\"What's your name?\" — \"My name ____ Ana.\"",
          "correct": "is",
          "explanation": "My name IS Ana. (Subject + to be)"
        },
        {
          "id": "q7",
          "type": "multiple-choice",
          "question": "Cashier: \"That's $5.50.\" — You:",
          "options": [
            "Here you go.",
            "Money.",
            "Take it.",
            "$5.50."
          ],
          "correct": 0,
          "explanation": "\"Here you go\" is natural when handing over payment."
        },
        {
          "id": "q8",
          "type": "multiple-choice",
          "question": "You want to leave. You say:",
          "options": [
            "I go now.",
            "Bye-bye.",
            "It was nice talking to you. See you later!",
            "I leave."
          ],
          "correct": 2,
          "explanation": "A complete farewell is more natural and polite."
        },
        {
          "id": "q9",
          "type": "fill-blank",
          "question": "At a hotel: \"I have a ____ under the name Smith.\"",
          "correct": "reservation",
          "explanation": "\"I have a reservation under [name]\" is the standard check-in phrase."
        },
        {
          "id": "q10",
          "type": "multiple-choice",
          "question": "\"How are you?\" — Best response:",
          "options": [
            "Good.",
            "I'm fine, thanks! And you?",
            "Yes.",
            "I am."
          ],
          "correct": 1,
          "explanation": "A complete response + asking back is the most natural."
        }
      ]
    }
  },
