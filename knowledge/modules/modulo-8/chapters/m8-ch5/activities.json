  {
    "id": "m8-ch5-flash",
    "type": "flashcard",
    "title": "Expresiones Conversacionales",
    "description": "Learn useful expressions organized by communicative function.",
    "props": {
      "cards": [
        {
          "id": "c1",
          "front": "🍽️ Ordering food",
          "back": "I'd like... / Could I have...? / I'll have the...",
          "example": "I'd like a hamburger and fries, please."
        },
        {
          "id": "c2",
          "front": "🛒 Shopping",
          "back": "How much is this? / Can I try this on? / Do you have a smaller size?",
          "example": "Excuse me, how much is this T-shirt?"
        },
        {
          "id": "c3",
          "front": "👋 Greeting",
          "back": "Hello! / Hi! / Good morning! / How are you?",
          "example": "Hi! How are you? — I'm great, thanks!"
        },
        {
          "id": "c4",
          "front": "🤝 Introducing yourself",
          "back": "My name is... / I'm... / I'm from... / I work as...",
          "example": "Hi, I'm Ana. I'm from Mexico. I'm a teacher."
        },
        {
          "id": "c5",
          "front": "🙏 Thanking",
          "back": "Thank you! / Thanks a lot! / I appreciate it!",
          "example": "Thank you so much for your help!"
        },
        {
          "id": "c6",
          "front": "👋 Saying goodbye",
          "back": "Goodbye! / See you later! / Have a nice day! / It was nice meeting you!",
          "example": "It was nice meeting you! See you later!"
        },
        {
          "id": "c7",
          "front": "❓ Asking for directions",
          "back": "Excuse me, where is...? / How do I get to...?",
          "example": "Excuse me, how do I get to the train station?"
        },
        {
          "id": "c8",
          "front": "😅 Not understanding",
          "back": "Sorry, could you repeat that? / I don't understand. / Could you speak slower?",
          "example": "Sorry, I don't understand. Could you speak slower, please?"
        },
        {
          "id": "c9",
          "front": "🙋 Asking for help",
          "back": "Excuse me, could you help me? / Can you help me with...?",
          "example": "Excuse me, could you help me find this address?"
        },
        {
          "id": "c10",
          "front": "🙏 Responding to thanks",
          "back": "You're welcome! / No problem! / My pleasure! / Anytime!",
          "example": "Thank you! — You're welcome!"
        },
        {
          "id": "c11",
          "front": "💳 Paying",
          "back": "How much is it? / Can I pay by card? / Here you go.",
          "example": "How much is it? — $15.50. — Here you go."
        },
        {
          "id": "c12",
          "front": "😔 Apologizing",
          "back": "I'm sorry / Excuse me / My apologies / Sorry about that",
          "example": "I'm sorry, I'm late. — No problem!"
        }
      ]
    }
  },
