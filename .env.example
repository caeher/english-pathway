# Supabase (cloud)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Local development (after `pnpm db:start`) ---
# Generate automatically with: pnpm db:env
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<see pnpm db:status>
# SUPABASE_SERVICE_ROLE_KEY=<see pnpm db:status>

# OAuth providers (set to "true" to show the button in auth forms)
NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_OAUTH_GITHUB_ENABLED=false

# App URL (used for OAuth and email redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# OpenAI — embeddings for RAG knowledge base (pnpm kb:embed)
OPENAI_API_KEY=
# This key is server-only and is also used by the English chat assistant.
# Never expose it with a NEXT_PUBLIC_ prefix.

# ElevenLabs — voice tutor on /learn
ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# In Supabase Dashboard → Auth → URL Configuration, also allowlist:
#   {NEXT_PUBLIC_APP_URL}/auth/callback
#   {NEXT_PUBLIC_APP_URL}/auth/callback?next=/reset-password
